#!/bin/sh

set -eu

if [ "${ALLOW_POC_CHANGES:-}" = "1" ]; then
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

echo "$staged_files" | while IFS= read -r file
do
  case "$file" in
    index.html|src/*|github-pages-upload/*|static/*|tests/*|logo-waterschap-limburg.jpg|PoC-publicatie-baseline.md)
      echo "Commit geblokkeerd: bevroren PoC-bestand geraakt: $file" >&2
      echo "Werk voor de migratie in docs/migratie/ of next/." >&2
      echo "Alleen bij expliciete uitzondering tijdelijk overrulen met ALLOW_POC_CHANGES=1." >&2
      exit 1
      ;;
  esac
done

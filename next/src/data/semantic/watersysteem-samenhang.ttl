@prefix object: <https://data.waterschaplimburg.nl/id/objecttype/> .
@prefix relatie: <https://data.waterschaplimburg.nl/def/relatie/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

object:watersysteem a owl:Class ;
  rdfs:label "Watersysteem" .

object:stroomgebied a owl:Class ;
  rdfs:label "Stroomgebied" .

object:watergang a owl:Class ;
  rdfs:label "Watergang" .

object:regenwaterbuffer a owl:Class ;
  rdfs:label "Regenwaterbuffer" .

object:watergangsectie a owl:Class ;
  rdfs:label "Watergangsectie" .

object:intersectie a owl:Class ;
  rdfs:label "Intersectie" .

object:regenwaterbuffercompartiment a owl:Class ;
  rdfs:label "Regenwaterbuffercompartiment" .

relatie:omvat a owl:ObjectProperty ;
  rdfs:label "omvat" .

relatie:bestaatUit a owl:ObjectProperty ;
  rdfs:label "bestaat uit" .

relatie:isOnderdeelVan a owl:ObjectProperty ;
  rdfs:label "is onderdeel van" .

object:watersysteem relatie:omvat object:stroomgebied .
object:stroomgebied relatie:isOnderdeelVan object:watersysteem .
object:stroomgebied relatie:omvat object:watergang .
object:stroomgebied relatie:omvat object:regenwaterbuffer .
object:watergang relatie:isOnderdeelVan object:stroomgebied .
object:regenwaterbuffer relatie:isOnderdeelVan object:stroomgebied .
object:watergang relatie:bestaatUit object:watergangsectie .
object:watergang relatie:bestaatUit object:intersectie .
object:regenwaterbuffer relatie:bestaatUit object:regenwaterbuffercompartiment .
object:watergangsectie relatie:isOnderdeelVan object:watergang .
object:intersectie relatie:isOnderdeelVan object:watergang .
object:regenwaterbuffercompartiment relatie:isOnderdeelVan object:regenwaterbuffer .

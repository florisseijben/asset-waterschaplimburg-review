---
import CardGrid from "./CardGrid.astro";
import ContentSectionCard from "./ContentSectionCard.astro";

interface SectionItem {
  title: string;
  summary: string;
  href?: string;
  items?: {
    title: string;
    text: string;
    href?: string;
    iconTitle?: string;
    image?: { src: string; alt?: string };
    caption?: string;
  }[];
  image?: { src: string; alt?: string };
  caption?: string;
  iconTitle?: string;
}

interface Props {
  title?: string;
  items?: SectionItem[];
}

const { title = "Inhoudelijke opbouw", items = [] } = Astro.props;
---

<section class="section section-panel">
  <p class="eyebrow">Uitwerking</p>
  <h2>{title}</h2>
  <CardGrid stacked={true}>
    {items.map((item) => (
      <ContentSectionCard
        title={item.title}
        text={item.summary}
        href={item.href}
        iconTitle={item.iconTitle}
        items={item.items}
        image={item.image}
        caption={item.caption}
      />
    ))}
  </CardGrid>
</section>

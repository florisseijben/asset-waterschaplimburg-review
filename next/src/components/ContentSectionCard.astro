---
import CardLinkIndicator from "./CardLinkIndicator.astro";
import CardTitleIcon from "./CardTitleIcon.astro";
import { withBase } from "../lib/paths";

interface SectionItem {
  title: string;
  text: string;
  href?: string;
  iconTitle?: string;
  image?: SectionImage;
  caption?: string;
}

interface SectionImage {
  src: string;
  alt?: string;
}

interface Props {
  title: string;
  text: string;
  href?: string;
  iconTitle?: string;
  items?: SectionItem[];
  image?: SectionImage;
  caption?: string;
}

const { title, text, href, iconTitle, items = [], image, caption } = Astro.props;
const hasItems = items.length > 0;
const hasImage = Boolean(image?.src);
const Tag = href && !hasItems ? "a" : "article";
---

<Tag
  class:list={["info-card", "info-card--section", hasImage && "info-card--with-image"]}
  href={href && !hasItems ? withBase(href) : undefined}
>
  <div class="info-card__header">
    <div class="info-card__title-wrap">
      {href && !hasItems && <CardTitleIcon title={iconTitle || title} />}
      <h2 class="info-card__title">{title}</h2>
    </div>
    {href && !hasItems && <CardLinkIndicator />}
  </div>
  <p>{text}</p>
  {image?.src && (
    <figure class="info-card__figure">
      <img class="info-card__image" src={withBase(image.src)} alt={image.alt || ""} loading="lazy" />
      {caption && <figcaption class="info-card__caption">{caption}</figcaption>}
    </figure>
  )}

  {hasItems && (
    <div class="card-grid card-grid--nested">
      {items.map((item) => {
        const ItemTag = item.href ? "a" : "article";
        const hasItemImage = Boolean(item.image?.src);
        return (
        <ItemTag
          class:list={["info-card", "info-card--nested", hasItemImage && "info-card--with-image"]}
          href={item.href ? withBase(item.href) : undefined}
        >
          <div class="info-card__header">
            <div class="info-card__title-wrap">
              {item.href && <CardTitleIcon title={item.iconTitle || item.title} />}
              <h3 class="info-card__title">{item.title}</h3>
            </div>
            {item.href && <CardLinkIndicator />}
          </div>
          <p>{item.text}</p>
          {item.image?.src && (
            <figure class="info-card__figure">
              <img class="info-card__image" src={withBase(item.image.src)} alt={item.image.alt || ""} loading="lazy" />
              {item.caption && <figcaption class="info-card__caption">{item.caption}</figcaption>}
            </figure>
          )}
        </ItemTag>
      )})}
    </div>
  )}
</Tag>

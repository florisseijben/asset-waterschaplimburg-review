---
import { withBase } from "../lib/paths";

interface SectionItem {
  title: string;
  text: string;
  href?: string;
  image?: SectionImage;
  caption?: string;
}

interface SectionImage {
  src: string;
  alt?: string;
}

interface Props {
  title: string;
  text: string;
  href?: string;
  items?: SectionItem[];
  image?: SectionImage;
  caption?: string;
}

const { title, text, href, items = [], image, caption } = Astro.props;
const hasItems = items.length > 0;
const Tag = href && !hasItems ? "a" : "article";
---

<Tag class:list={["info-card", "info-card--section"]} href={href && !hasItems ? withBase(href) : undefined}>
  <h2>{title}</h2>
  <p>{text}</p>
  {image?.src && (
    <figure class="info-card__figure">
      <img class="info-card__image" src={withBase(image.src)} alt={image.alt || ""} loading="lazy" />
      {caption && <figcaption class="info-card__caption">{caption}</figcaption>}
    </figure>
  )}
  {href && !hasItems && (
    <span class="info-card__link">
      <svg viewBox="0 0 24 24" class="info-card__icon" focusable="false" aria-hidden="true">
        <path
          d="M8 8h8v8M16 8l-9 9"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
        />
      </svg>
      <span class="visually-hidden">Open deze pagina</span>
    </span>
  )}

  {hasItems && (
    <div class="card-grid card-grid--nested">
      {items.map((item) => {
        const ItemTag = item.href ? "a" : "article";
        return (
        <ItemTag class="info-card info-card--nested" href={item.href ? withBase(item.href) : undefined}>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
          {item.image?.src && (
            <figure class="info-card__figure">
              <img class="info-card__image" src={withBase(item.image.src)} alt={item.image.alt || ""} loading="lazy" />
              {item.caption && <figcaption class="info-card__caption">{item.caption}</figcaption>}
            </figure>
          )}
          {item.href && (
            <span class="info-card__link">
              <svg viewBox="0 0 24 24" class="info-card__icon" focusable="false" aria-hidden="true">
                <path
                  d="M8 8h8v8M16 8l-9 9"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.8"
                />
              </svg>
              <span class="visually-hidden">Open deze pagina</span>
            </span>
          )}
        </ItemTag>
      )})}
    </div>
  )}
</Tag>

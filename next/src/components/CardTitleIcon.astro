---
interface Props {
  title: string;
}

const { title } = Astro.props;
const normalizedTitle = title.trim().toLowerCase();

const titleIcons: Record<string, string> = {
  "afvalwaterketen": "system-pipes",
  "watersysteem": "system-water",
  "waterkeringensysteem": "system-shield",
  "terreinbeheer en openbare ruimte": "discipline-road",
  "ecologie en groen": "discipline-eco",
  "civiele techniek": "discipline-civil",
  bouwkunde: "discipline-building",
  werktuigbouwkunde: "discipline-mechanical",
  electrotechniek: "discipline-electric",
  procesautomatisering: "discipline-automation",
  "informatie en data": "discipline-data",
  "ruimtelijke ordening": "discipline-spatial",
  groen: "discipline-green",
  woordenboek: "product-book",
  objectenhandboek: "product-cube",
  "object type library": "product-library",
  referentiedataset: "product-database",
  werkinstructies: "product-checklist"
};

const matches = (...terms: string[]) => terms.some((term) => normalizedTitle.includes(term));

const icon =
  titleIcons[normalizedTitle] ||
  (matches("water", "stroom", "beek", "gracht", "kanaal", "rivier", "sloot") ? "system-water" :
  matches("geo", "kaart", "locatie", "gebied") ? "discipline-spatial" :
  matches("woordenboek", "begrip", "term", "taal") ? "product-book" :
  matches("object", "onderdeel", "sectie", "constructie", "bekleding", "talud", "buffer", "intersectie") ? "product-cube" :
  matches("referentie", "dataset", "data", "informatie") ? "product-database" :
  matches("werkinstruct", "proces", "beheer", "management") ? "product-checklist" :
  matches("discipline", "techniek", "bouw", "electro", "ecologie", "groen", "werktuig") ? "discipline-mechanical" :
  matches("systeem", "keten", "register") ? "discipline-data" :
  "document");
---

<span class="info-card__title-icon" aria-hidden="true">
  {icon === "system-pipes" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M4 8h7v4h2V7h7M20 7v10M13 17H4m7 0v-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "system-water" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M6 14c0-3.5 3-5.9 6-9 3 3.1 6 5.5 6 9a6 6 0 1 1-12 0Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "system-shield" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M12 3 19 6v5c0 4.6-2.8 7.8-7 10-4.2-2.2-7-5.4-7-10V6l7-3Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M8 12c1-.8 2-.8 3 0s2 .8 3 0 2-.8 3 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-road" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="m9 4-3 16M15 4l3 16M10.5 8h3M9.8 12h4.4M9 16h6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-eco" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M12 19c0-5 3-9 8-11 0 7-3 11-8 11ZM12 19c0-4-2.5-7.2-7-9 0 5.8 2.3 9 7 9ZM12 19V9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-civil" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M4 17h16M6 17v-3a6 6 0 0 1 12 0v3M9 17v-4M15 17v-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-building" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M5 20V6l7-3 7 3v14M9 8h1M14 8h1M9 12h1M14 12h1M11 20v-4h2v4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-mechanical" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="m14 6 4 4M5 19l8.5-8.5a3 3 0 1 0-4-4L1 15v4h4Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M17.5 14.5v3M16 16h3M15.4 13.9l1.1 1.1M19.6 18.1l1.1 1.1M19.6 13.9 18.5 15M15.4 18.1 16.5 17" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.4" />
    </svg>
  )}
  {icon === "discipline-electric" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M13 2 6 13h5l-1 9 8-12h-5l0-8Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-automation" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M6 4v16M12 4v16M18 4v16M4 8h4M10 15h4M16 10h4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-data" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M7 7h4v4H7zM13 13h4v4h-4zM13 4h4v4h-4zM7 16h4v4H7zM11 9h2m2-1v5m-4 4h2" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "discipline-spatial" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M4 5h16v14H4zM9.5 5v14M14.5 5v14M4 10h16M4 15h16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" />
    </svg>
  )}
  {icon === "discipline-green" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M6 14c0-5 4-9 12-10-1 8-5 12-10 12-1 0-2 0-2-2Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M8 16c2-3 5-5 9-7" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "product-book" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M5 6.5A2.5 2.5 0 0 1 7.5 4H19v15H7.5A2.5 2.5 0 0 0 5 21V6.5Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M8 8h7M8 12h7" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "product-cube" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M12 12 4 7.5M12 12l8-4.5M12 12v9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "product-library" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="m8 5 4 2.2v4.6L8 14l-4-2.2V7.2L8 5Zm8 0 4 2.2v4.6L16 14l-4-2.2V7.2L16 5ZM12 12l4 2.2v4.6L12 21l-4-2.2v-4.6L12 12Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.6" />
    </svg>
  )}
  {icon === "product-database" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <ellipse cx="12" cy="6" rx="7" ry="3" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "product-checklist" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M8 5h11v16H5V5h3ZM9 10h6M9 15h6M7.5 10l1 1 1.5-2M7.5 15l1 1 1.5-2M9 3h6v4H9z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "document" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M7 3h7l5 5v13H7z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M14 3v5h5M9 13h6M9 17h6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
</span>

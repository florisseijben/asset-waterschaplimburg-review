---
interface Props {
  title: string;
}

const { title } = Astro.props;
const normalizedTitle = title.toLowerCase();

const matches = (...terms: string[]) => terms.some((term) => normalizedTitle.includes(term));

let icon = "document";

if (matches("water", "stroom", "beek", "gracht", "kanaal", "rivier", "sloot")) {
  icon = "water";
} else if (matches("geo", "kaart", "locatie", "gebied")) {
  icon = "map";
} else if (matches("woordenboek", "begrip", "term", "taal")) {
  icon = "book";
} else if (matches("object", "onderdeel", "sectie", "constructie", "bekleding", "talud", "buffer", "intersectie")) {
  icon = "cube";
} else if (matches("referentie", "dataset", "data", "informatie")) {
  icon = "database";
} else if (matches("werkinstruct", "proces", "beheer", "management")) {
  icon = "settings";
} else if (matches("discipline", "techniek", "bouw", "electro", "ecologie", "groen", "werktuig")) {
  icon = "tool";
} else if (matches("systeem", "keten", "register")) {
  icon = "network";
}
---

<span class="info-card__title-icon" aria-hidden="true">
  {icon === "water" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M6 14c0-3.5 3-5.9 6-9 3 3.1 6 5.5 6 9a6 6 0 1 1-12 0Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "map" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M9 5 3 7v12l6-2 6 2 6-2V5l-6 2-6-2Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M9 5v12M15 7v12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "book" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M5 6.5A2.5 2.5 0 0 1 7.5 4H19v15H7.5A2.5 2.5 0 0 0 5 21V6.5Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M8 8h7M8 12h7" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "cube" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M12 12 4 7.5M12 12l8-4.5M12 12v9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "database" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <ellipse cx="12" cy="6" rx="7" ry="3" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "settings" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M12 8.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 1 0 12 8.5Z" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="M19 12a7.6 7.6 0 0 0-.1-1l2-1.6-2-3.4-2.5 1a8 8 0 0 0-1.8-1l-.4-2.6H10l-.4 2.6a8 8 0 0 0-1.8 1l-2.5-1-2 3.4 2 1.6a7.6 7.6 0 0 0 0 2l-2 1.6 2 3.4 2.5-1a8 8 0 0 0 1.8 1L10 20.6h4l.4-2.6a8 8 0 0 0 1.8-1l2.5 1 2-3.4-2-1.6c.1-.3.1-.7.1-1Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" />
    </svg>
  )}
  {icon === "tool" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="m14 6 4 4M5 19l8.5-8.5a3 3 0 1 0-4-4L1 15v4h4Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "network" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M12 5v14M5 9h14M7 5h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
  {icon === "document" && (
    <svg viewBox="0 0 24 24" class="info-card__title-icon-svg" focusable="false">
      <path d="M7 3h7l5 5v13H7z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
      <path d="M14 3v5h5M9 13h6M9 17h6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
    </svg>
  )}
</span>

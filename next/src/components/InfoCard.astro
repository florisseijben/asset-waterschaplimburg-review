---
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  text: string;
  href?: string;
  eyebrow?: string;
}

const { title, text, href, eyebrow } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag class="info-card" href={withBase(href)}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  <p>{text}</p>
  {href && (
    <span class="info-card__link">
      <svg viewBox="0 0 24 24" class="info-card__icon" focusable="false" aria-hidden="true">
        <path
          d="M8 8h8v8M16 8l-9 9"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
        />
      </svg>
      <span class="visually-hidden">Open deze pagina</span>
    </span>
  )}
</Tag>

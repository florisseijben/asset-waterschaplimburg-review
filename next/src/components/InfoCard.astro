---
import CardLinkIndicator from "./CardLinkIndicator.astro";
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  text?: string;
  href?: string;
  eyebrow?: string;
}

const { title, text, href, eyebrow } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag class="info-card" href={withBase(href)}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <div class="info-card__header">
    <h2 class="info-card__title">{title}</h2>
    {href && <CardLinkIndicator />}
  </div>
  {text && <p>{text}</p>}
  <slot />
</Tag>

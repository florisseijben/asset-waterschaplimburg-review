---
interface Props {
  label?: string;
}

const { label = "Open deze pagina" } = Astro.props;
---

<span class="info-card__link">
  <svg viewBox="0 0 24 24" class="info-card__icon" focusable="false" aria-hidden="true">
    <path
      d="M8 8h8v8M16 8l-9 9"
      fill="none"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.8"
    />
  </svg>
  <span class="visually-hidden">{label}</span>
</span>

---
import { withBase } from "../lib/paths";
import { getObjectTypeHref } from "../lib/objectTypeRoutes";

interface TermItem {
  title: string;
  text?: string;
  href?: string;
}

interface Props {
  subjectLabel: string;
  definition?: string;
  synonyms?: TermItem[];
  relatedTerms?: TermItem[];
  definitionTypes?: TermItem[];
  subtypes?: TermItem[];
  runtimeSourceUrl?: string;
  runtimeSourceLabel?: string;
  showTypes?: boolean;
}

const {
  subjectLabel,
  definition,
  synonyms = [],
  relatedTerms = [],
  definitionTypes = [],
  subtypes = [],
  runtimeSourceUrl,
  runtimeSourceLabel = "IMBOR",
  showTypes
} = Astro.props;

const conceptTypes = definitionTypes.length > 0 ? definitionTypes : subtypes;
const hasSynonyms = synonyms.length > 0;
const hasRelatedTerms = relatedTerms.length > 0;
const hasConceptTypes = conceptTypes.length > 0;
const shouldShowTypes = showTypes ?? hasConceptTypes;
const runtimeId = `concept-runtime-${subjectLabel.toLowerCase().replace(/\s+/g, "-")}`;
const getRelatedHref = (item: TermItem) => getObjectTypeHref(item.title, item.href || "/datastandaard/woordenboek");
const getConceptTypeHref = (item: TermItem) => item.href || "/datastandaard/woordenboek";
---

<section class="section section-panel">
  <p class="eyebrow">Begrip</p>
  <h2>Wat verstaan we onder {subjectLabel}?</h2>

  <div class="concept-runtime-note" id={runtimeId} hidden></div>

  <div class="concept-summary">
    <div class="concept-summary__row">
      <strong>Definitie</strong>
      <div>
        <p data-concept-definition>{definition}</p>
      </div>
    </div>

    <details class="concept-disclosure">
      <summary>Synoniemen</summary>
      <div class="concept-disclosure__body" data-concept-synonyms>
        {hasSynonyms ? (
          <div class="concept-summary__list">
            {synonyms.map((item) => (
              <a class="concept-summary__item" href={withBase(item.href || "/datastandaard/woordenboek")}>
                <strong>{item.title}</strong>
                <span>{item.text || "Open begrip in woordenboek."}</span>
              </a>
            ))}
          </div>
        ) : (
          <span class="concept-summary__empty">Geen aparte synoniemen uitgewerkt.</span>
        )}
      </div>
    </details>

    <details class="concept-disclosure">
      <summary>Gerelateerde termen</summary>
      <div class="concept-disclosure__body" data-concept-related>
        {hasRelatedTerms ? (
          <div class="concept-summary__list">
            {relatedTerms.map((item) => (
              <a class="concept-summary__item" href={withBase(getRelatedHref(item))}>
                <strong>{item.title}</strong>
                <span>{item.text || "Open begrip in woordenboek."}</span>
              </a>
            ))}
          </div>
        ) : (
          <span class="concept-summary__empty">Geen gerelateerde termen uitgewerkt.</span>
        )}
      </div>
    </details>

    {shouldShowTypes && (
      <details class="concept-disclosure">
        <summary>Typen naar definitie</summary>
        <div class="concept-disclosure__body" data-concept-types>
          {hasConceptTypes ? (
            <div class="concept-summary__list">
              {conceptTypes.map((item) => (
                <a class="concept-summary__item" href={withBase(getConceptTypeHref(item))}>
                  <strong>{item.title}</strong>
                  <span>{item.text || "Open begrip in het woordenboek."}</span>
                </a>
              ))}
            </div>
          ) : (
            <span class="concept-summary__empty">Geen begripsmatige typen uitgewerkt.</span>
          )}
        </div>
      </details>
    )}
  </div>
</section>

{runtimeSourceUrl && (
  <script
    is:inline
    define:vars={{
      runtimeId,
      runtimeSourceUrl,
      runtimeSourceLabel
    }}
  >
    const note = document.getElementById(runtimeId);
    const root = note?.closest(".section-panel");
    const definitionNode = root?.querySelector("[data-concept-definition]");
    const synonymsBody = root?.querySelector("[data-concept-synonyms]");
    const relatedBody = root?.querySelector("[data-concept-related]");
    const typesBody = root?.querySelector("[data-concept-types]");

    const fallbackMessage = `Live ophalen uit ${runtimeSourceLabel} lukte niet. Hieronder zie je de build-time versie.`;
    const successMessage = `Begripsinformatie is live bijgewerkt vanuit ${runtimeSourceLabel}.`;
    const getObjectTypeHref = () => "/datastandaard/woordenboek";

    const createListMarkup = (items) => {
      if (!items?.length) {
        return '<span class="concept-summary__empty">Geen informatie beschikbaar.</span>';
      }

      const rows = items
        .map(
          (item) => `
            <a class="concept-summary__item" href="${getObjectTypeHref(item.title)}">
              <strong>${item.title}</strong>
              <span>${item.text || "Live opgehaald uit IMBOR."}</span>
            </a>
          `
        )
        .join("");

      return `<div class="concept-summary__list">${rows}</div>`;
    };

    const collectListItems = (html, headingLabel) => {
      const regex = new RegExp(
        `<h3[^>]*>\\s*${headingLabel}\\s*<\\/h3>[\\s\\S]*?<ul[^>]*>([\\s\\S]*?)<\\/ul>`,
        "i"
      );
      const match = html.match(regex);
      if (!match?.[1]) {
        return [];
      }

      return [...match[1].matchAll(/<li[^>]*>\s*([\s\S]*?)\s*<\/li>/gi)]
        .map((item) => item[1].replace(/<[^>]+>/g, "").trim())
        .filter(Boolean)
        .map((title) => ({ title, text: "Live opgehaald uit IMBOR." }));
    };

    const parseDefinition = (html) => {
      const match = html.match(/<h3[^>]*>\s*definitie\s*<\/h3>[\s\S]*?<li[^>]*>\s*([\s\S]*?)\s*<\/li>/i);
      if (!match?.[1]) {
        return "";
      }

      return match[1].replace(/<[^>]+>/g, "").trim();
    };

    fetch(runtimeSourceUrl, { mode: "cors" })
      .then((response) => {
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        return response.text();
      })
      .then((html) => {
        const parsedDefinition = parseDefinition(html);
        const parsedRelated = collectListItems(html, "heeft bovenliggend begrip");
        const parsedTypes = collectListItems(html, "heeft onderliggend begrip");

        if (parsedDefinition && definitionNode) {
          definitionNode.textContent = parsedDefinition;
        }

        if (parsedRelated.length && relatedBody) {
          relatedBody.innerHTML = createListMarkup(parsedRelated);
        }

        if (parsedTypes.length && typesBody) {
          typesBody.innerHTML = createListMarkup(parsedTypes);
        }

        if (note) {
          note.hidden = false;
          note.textContent = successMessage;
          note.dataset.state = "success";
        }
      })
      .catch(() => {
        if (note) {
          note.hidden = false;
          note.textContent = fallbackMessage;
          note.dataset.state = "fallback";
        }
      });
  </script>
)}

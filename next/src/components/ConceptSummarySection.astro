---
import { withBase } from "../lib/paths";

interface TermItem {
  title: string;
  text?: string;
  href?: string;
}

interface Props {
  subjectLabel: string;
  definition?: string;
  definitionSource?: string;
  synonyms?: TermItem[];
  relatedTerms?: TermItem[];
  subtypes?: TermItem[];
}

const {
  subjectLabel,
  definition,
  definitionSource,
  synonyms = [],
  relatedTerms = [],
  subtypes = []
} = Astro.props;

const hasSynonyms = synonyms.length > 0;
const hasRelatedTerms = relatedTerms.length > 0;
const hasSubtypes = subtypes.length > 0;
---

<section class="section section-panel">
  <p class="eyebrow">Begrip</p>
  <h2>Wat verstaan we onder {subjectLabel}?</h2>

  <div class="concept-summary">
    <div class="concept-summary__row">
      <strong>Definitie</strong>
      <div>
        <p>{definition}</p>
        <p class="concept-summary__linkline">
          <a href={withBase("/datastandaard/woordenboek")}>Bekijk dit begrip in het woordenboek</a>
        </p>
        {definitionSource && <p class="concept-summary__source">{definitionSource}</p>}
      </div>
    </div>

    <details class="concept-disclosure">
      <summary>Synoniemen</summary>
      <div class="concept-disclosure__body">
        {hasSynonyms ? (
          <div class="concept-summary__list">
            {synonyms.map((item) => (
              <a class="concept-summary__item" href={withBase(item.href || "/datastandaard/woordenboek")}>
                <strong>{item.title}</strong>
                <span>{item.text || "Open begrip in woordenboek."}</span>
              </a>
            ))}
          </div>
        ) : (
          <span class="concept-summary__empty">Geen aparte synoniemen uitgewerkt.</span>
        )}
      </div>
    </details>

    <details class="concept-disclosure">
      <summary>Gerelateerde termen</summary>
      <div class="concept-disclosure__body">
        {hasRelatedTerms ? (
          <div class="concept-summary__list">
            {relatedTerms.map((item) => (
              <a class="concept-summary__item" href={withBase(item.href || "/datastandaard/woordenboek")}>
                <strong>{item.title}</strong>
                <span>{item.text || "Open begrip in woordenboek."}</span>
              </a>
            ))}
          </div>
        ) : (
          <span class="concept-summary__empty">Geen gerelateerde termen uitgewerkt.</span>
        )}
      </div>
    </details>

    <details class="concept-disclosure">
      <summary>Typen</summary>
      <div class="concept-disclosure__body">
        {hasSubtypes ? (
          <div class="concept-summary__list">
            {subtypes.map((item) => (
              <a class="concept-summary__item" href={withBase(item.href || "/datastandaard/woordenboek")}>
                <strong>{item.title}</strong>
                <span>{item.text || "Open begrip in woordenboek."}</span>
              </a>
            ))}
          </div>
        ) : (
          <span class="concept-summary__empty">Geen typen uitgewerkt.</span>
        )}
      </div>
    </details>
  </div>
</section>

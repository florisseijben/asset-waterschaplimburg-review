---
import InfoCard from "./InfoCard.astro";

interface StepItem {
  title: string;
  text: string;
  href?: string;
  direction?: "back" | "forward";
}

interface Props {
  items?: StepItem[];
}

const { items = [] } = Astro.props;

const inferDirection = (item: StepItem) => {
  if (item.direction === "back" || item.direction === "forward") {
    return item.direction;
  }

  const candidate = `${item.title} ${item.text}`.toLowerCase();
  if (
    candidate.includes("terug naar") ||
    candidate.includes("bovenliggend") ||
    candidate.includes("terug ")
  ) {
    return "back";
  }

  return "forward";
};

const backItems = items.filter((item) => inferDirection(item) === "back");
const forwardItems = items.filter((item) => inferDirection(item) === "forward");
const hasBackItems = backItems.length > 0;
const hasForwardItems = forwardItems.length > 0;
const isSingleColumn = hasBackItems !== hasForwardItems;
const singleColumnItems = hasBackItems ? backItems : forwardItems;
const rowCount = Math.max(backItems.length, forwardItems.length);
const rows = Array.from({ length: rowCount }, (_, index) => ({
  back: backItems[index],
  forward: forwardItems[index]
}));
---

<div class:list={["next-steps-layout", isSingleColumn && "next-steps-layout--single"]}>
  {isSingleColumn ? (
    singleColumnItems.map((item) => (
      <div class:list={["next-steps-cell", hasBackItems ? "next-steps-cell--back" : "next-steps-cell--forward"]}>
        <InfoCard title={item.title} text={item.text} href={item.href} eyebrow={hasBackItems ? "<- Terug" : "Verder ->"} />
      </div>
    ))
  ) : (
    rows.map((row) => (
      <>
        <div class="next-steps-cell next-steps-cell--back">
          {row.back && <InfoCard title={row.back.title} text={row.back.text} href={row.back.href} eyebrow="<- Terug" />}
        </div>
        <div class="next-steps-cell next-steps-cell--forward">
          {row.forward && <InfoCard title={row.forward.title} text={row.forward.text} href={row.forward.href} eyebrow="Verder ->" />}
        </div>
      </>
    ))
  )}
</div>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import PlaceholderStatus from "../../components/PlaceholderStatus.astro";

---

<BaseLayout
  title="Assetmanagement"
  currentPath="/assetmanagement"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Assetmanagement" }]}
>
  <Hero
    eyebrow="Assetmanagement"
    title="Assetmanagement"
    summary="Op deze pagina vind je straks de assetmanagementlijn: processen, rollen, sturing en afspraken waarmee assetinformatie wordt gebruikt voor programmering, uitvoering, verantwoording en verbetering."
  />

  <PlaceholderStatus
    title="Assetmanagement volgt in een volgende slice"
    summary="De hoofdstructuur van het platform is nu al zichtbaar, ook als deze productlijn inhoudelijk nog niet volledig is gemigreerd."
    scope="de landingspagina en de sturings- en proceslijnen van Assetmanagement"
  />
</BaseLayout>

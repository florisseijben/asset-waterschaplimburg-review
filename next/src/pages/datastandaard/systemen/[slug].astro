---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import ProductSection from "../../../components/ProductSection.astro";

export function getStaticPaths() {
  const systemPages = [
    {
      slug: "afvalwaterketen",
      title: "Afvalwaterketen",
      summary:
        "Op deze systeempagina vind je de producten van de Datastandaard voor de Afvalwaterketen: begrippen, objecttypen, OTL, referentiegegevens en werkinstructies voor zuivering, transport en pompvoorzieningen.",
      intro:
        "Gebruik deze ingang als je de datastandaard wilt benaderen vanuit RWZI's, rioolgemalen, transportleidingen en aanverwante objecten.",
      productCards: [
        { title: "Woordenboek", text: "Dit product is het naslagwerk dat informatie biedt over begrippen, zoals betekenis, synoniemen en relaties tussen begrippen.", href: "/datastandaard/woordenboek" },
        { title: "Objectenhandboek", text: "Objecttypen en systeemstructuur voor de Afvalwaterketen.", href: "/datastandaard/objectenhandboek/afvalwaterketen" },
        { title: "Object Type Library", text: "Dit product definieert de eigenschappen, relaties en het gedrag van een bepaald type object in een gestandaardiseerde vorm.", href: "/datastandaard/otl" },
        { title: "Referentiedataset", text: "Voorbeelddata en toetsbare referenties voor dit systeem.", href: "/datastandaard/referentiedataset" },
        { title: "Werkinstructies", text: "Gebruiks- en beheerafspraken voor toepassing van de standaard.", href: "/datastandaard/werkinstructies" }
      ]
    },
    {
      slug: "watersysteem",
      title: "Watersysteem",
      summary:
        "Op deze systeempagina vind je de producten van de Datastandaard voor het Watersysteem: begrippen, objecttypen, OTL, referentiegegevens en werkinstructies voor stroomgebieden, watergangen, buffers en kunstwerken.",
      intro:
        "Gebruik deze ingang als je de datastandaard wilt benaderen vanuit stroomgebieden, watergangen, watervlakten, buffers, kunstwerken en terreininrichting.",
      productCards: [
        { title: "Woordenboek", text: "Dit product is het naslagwerk dat informatie biedt over begrippen, zoals betekenis, synoniemen en relaties tussen begrippen.", href: "/datastandaard/woordenboek" },
        { title: "Objectenhandboek", text: "Objecttypen en systeemstructuur voor het Watersysteem.", href: "/datastandaard/objectenhandboek/watersysteem" },
        { title: "Object Type Library", text: "Dit product definieert de eigenschappen, relaties en het gedrag van een bepaald type object in een gestandaardiseerde vorm.", href: "/datastandaard/otl" },
        { title: "Referentiedataset", text: "Voorbeelddata en toetsbare referenties voor dit systeem.", href: "/datastandaard/referentiedataset" },
        { title: "Werkinstructies", text: "Gebruiks- en beheerafspraken voor toepassing van de standaard.", href: "/datastandaard/werkinstructies" }
      ]
    },
    {
      slug: "waterkeringensysteem",
      title: "Waterkeringensysteem",
      summary:
        "Op deze systeempagina vind je de producten van de Datastandaard voor het Waterkeringensysteem: begrippen, objecttypen, OTL, referentiegegevens en werkinstructies voor keringen, constructies, terreinen en groenobjecten.",
      intro:
        "Gebruik deze ingang als je de datastandaard wilt benaderen vanuit waterkeringen, langsconstructies, kunstwerken, terreinen en groenobjecten.",
      productCards: [
        { title: "Woordenboek", text: "Dit product is het naslagwerk dat informatie biedt over begrippen, zoals betekenis, synoniemen en relaties tussen begrippen.", href: "/datastandaard/woordenboek" },
        { title: "Objectenhandboek", text: "Objecttypen en systeemstructuur voor het Waterkeringensysteem.", href: "/datastandaard/objectenhandboek/waterkeringensysteem" },
        { title: "Object Type Library", text: "Dit product definieert de eigenschappen, relaties en het gedrag van een bepaald type object in een gestandaardiseerde vorm.", href: "/datastandaard/otl" },
        { title: "Referentiedataset", text: "Voorbeelddata en toetsbare referenties voor dit systeem.", href: "/datastandaard/referentiedataset" },
        { title: "Werkinstructies", text: "Gebruiks- en beheerafspraken voor toepassing van de standaard.", href: "/datastandaard/werkinstructies" }
      ]
    }
  ];

  return systemPages.map((page) => ({
    params: { slug: page.slug },
    props: page
  }));
}

const { title, summary, productCards } = Astro.props;
---

<BaseLayout
  title={title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: title }
  ]}
>
  <Hero eyebrow="Systeem" title={title} summary={summary} />

  <ProductSection items={productCards} />
</BaseLayout>

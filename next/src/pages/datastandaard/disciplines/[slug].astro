---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import CardGrid from "../../../components/CardGrid.astro";
import InfoCard from "../../../components/InfoCard.astro";
import ConceptReference from "../../../components/ConceptReference.astro";

export function getStaticPaths() {
  const disciplinePages = [
    {
      slug: "terreinbeheer-openbare-ruimte",
      title: "Terreinbeheer en openbare ruimte",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor terreinbeheer en openbare ruimte bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit terreinen, gebruiksruimte, paden, verhardingen, inrichting, bereikbaarheid en beheer van de buitenruimte.",
    },
    {
      slug: "ecologie-en-groen",
      title: "Ecologie en groen",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor ecologie en groen bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit vegetatie, ecologische functies, natuurvriendelijke inrichting en groenbeheer.",
    },
    {
      slug: "civiele-techniek",
      title: "Civiele techniek",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor civiele techniek bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit profielen, constructies, kunstwerken, watergangen, buffers en waterkeringen.",
    },
    {
      slug: "bouwkunde",
      title: "Bouwkunde",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor bouwkunde bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit gebouwen, bassins, bouwdelen, fundaties en gebouwgebonden objecten.",
    },
    {
      slug: "werktuigbouwkunde",
      title: "Werktuigbouwkunde",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor werktuigbouwkunde bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit pompen, afsluiters, roerwerken, transportsystemen en mechanische installaties.",
    },
    {
      slug: "electrotechniek",
      title: "Electrotechniek",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor elektrotechniek bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit voedingen, verdeelinrichtingen, bekabeling, aandrijvingen en elektrische componenten.",
    },
    {
      slug: "procesautomatisering",
      title: "Procesautomatisering",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor procesautomatisering bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit sensoren, metingen, PLC/SCADA, sturing, regeling en alarmering.",
    },
    {
      slug: "informatie-en-data",
      title: "Informatie en data",
      summary: "Op deze pagina vind je de producten van de Datastandaard voor informatie en data bij elkaar.",
      intro: "Gebruik deze ingang als je de datastandaard wilt lezen vanuit begrippen, objectafbakening, datamodellen, geometrie, metadata, kwaliteitseisen en gegevensuitwisseling.",
    }
  ].map((page) => ({
    ...page,
    productCards: [
      { title: "Woordenboek", text: "Dit product is het naslagwerk dat informatie biedt over begrippen, zoals betekenis, synoniemen en relaties tussen begrippen.", href: "/datastandaard/woordenboek" },
      { title: "Objectenhandboek", text: `Objecttypen en structuur bekeken vanuit ${page.title}.`, href: "/datastandaard/objectenhandboek" },
      { title: "Object Type Library", text: "Dit product definieert de eigenschappen, relaties en het gedrag van een bepaald type object in een gestandaardiseerde vorm.", href: "/datastandaard/otl" },
      { title: "Referentiedataset", text: `Voorbeelddata en referenties bekeken vanuit ${page.title}.`, href: "/datastandaard/referentiedataset" },
      { title: "Werkinstructies", text: `Werkinstructies en gebruiksafspraken bekeken vanuit ${page.title}.`, href: "/datastandaard/werkinstructies" }
    ]
  }));

  return disciplinePages.map((page) => ({
    params: { slug: page.slug },
    props: page
  }));
}

const { title, summary, intro, productCards } = Astro.props;
---

<BaseLayout
  title={title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: title }
  ]}
>
  <Hero eyebrow="Discipline" title={title} summary={summary} />

  <ConceptReference concept={title} kind="Discipline" />

  <section class="section section-panel">
    <p class="eyebrow">Benadering</p>
    <h2>Werk verder vanuit deze discipline</h2>
    <div class="content-copy">
      <p>{intro}</p>
    </div>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Producten</p>
    <h2>Kies een productlijn binnen {title}</h2>
    <CardGrid roomy>
      {productCards.map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>
</BaseLayout>

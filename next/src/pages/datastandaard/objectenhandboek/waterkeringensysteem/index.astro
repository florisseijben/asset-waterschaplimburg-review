---
import ObjectenhandboekChapterPage from "../../../../components/ObjectenhandboekChapterPage.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("datastandaard-objectenhandboek-systems");
const expectedSlug = "/datastandaard/objectenhandboek/waterkeringensysteem";
const entry = entries.find(
  (item) =>
    item.id === "waterkeringensysteem" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Objectenhandboek voor Waterkeringensysteem"
);

if (!entry) {
  throw new Error("Objectenhandboek Waterkeringensysteem ontbreekt in de nieuwe omgeving.");
}
---

<ObjectenhandboekChapterPage
  entry={entry}
  subjectLabel="Waterkeringensysteem"
  handbookHref="/datastandaard/objectenhandboek/handboeken/waterkeringen"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Waterkeringensysteem" }
  ]}
/>

---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Hero from "../../../../components/Hero.astro";
import PlaceholderStatus from "../../../../components/PlaceholderStatus.astro";

---

<BaseLayout
  title="Objectenhandboek voor Waterkeringensysteem"
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Waterkeringensysteem" }
  ]}
>
  <Hero
    eyebrow="Objectenhandboek"
    title="Objectenhandboek voor Waterkeringensysteem"
    summary="Deze systeempagina is gereserveerd voor een volgende inhoudelijke migratieslice binnen het Objectenhandboek."
  />

  <PlaceholderStatus
    title="Waterkeringensysteem volgt na Watersysteem"
    summary="De systeemroute is alvast klikbaar gemaakt zodat de productstructuur volledig zichtbaar blijft in de preview."
    scope="de systeemuitwerking van het Waterkeringensysteem binnen het Objectenhandboek"
  />
</BaseLayout>

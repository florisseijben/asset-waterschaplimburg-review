---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import CardGrid from "../../../components/CardGrid.astro";
import InfoCard from "../../../components/InfoCard.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("datastandaard-objectenhandboek");
const entry = entries[0];

if (!entry) {
  throw new Error("Objectenhandboek-landing ontbreekt in de nieuwe omgeving.");
}
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek" }
  ]}
>
  <Hero eyebrow="Product" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary} />

  <section class="section section-panel">
    <p class="eyebrow">Systemen</p>
    <h2>Kies een systeem</h2>
    <CardGrid roomy>
      {(entry.data.systems || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Disciplines</p>
    <h2>Bekijk het objectenhandboek per discipline</h2>
    <CardGrid roomy>
      {(entry.data.disciplines || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>
</BaseLayout>

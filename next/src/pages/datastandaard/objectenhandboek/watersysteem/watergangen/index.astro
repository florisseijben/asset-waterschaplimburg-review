---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../components/Hero.astro";
import ConceptSummarySection from "../../../../../components/ConceptSummarySection.astro";
import NextStepsSection from "../../../../../components/NextStepsSection.astro";
import SemanticSamenhangSection from "../../../../../components/SemanticSamenhangSection.astro";
import ProductSection from "../../../../../components/ProductSection.astro";
import UitwerkingSection from "../../../../../components/UitwerkingSection.astro";
import { getCollection } from "astro:content";
import {
  createWatergangSamenhangFromAssetJson,
  getConceptFromAssetJson,
  getDecompositionFromAssetJson
} from "../../../../../lib/assetConcepts";

const entries = await getCollection("datastandaard-objectenhandboek-objects");
const expectedSlug = "/datastandaard/objectenhandboek/watersysteem/watergangen";
const entry = entries.find(
  (item) =>
    item.id === "watergangen" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Watergang"
);

if (!entry) {
  throw new Error("Objectenhandboek Watergangen ontbreekt in de nieuwe omgeving.");
}

const conceptData = getConceptFromAssetJson("Watergang");
const decompositionData = getDecompositionFromAssetJson("Watergang");
const samenhangData = createWatergangSamenhangFromAssetJson();
const visibleContentSections = (entry.data.contentSections || [])
  .filter((item) => item.title !== "Decompositie")
  .map((item) =>
    item.title === "Onderdelen" && decompositionData
      ? {
          ...item,
          summary: decompositionData.summary,
          items: decompositionData.items
        }
      : item
  );
const fallbackSamenhang = {
  sourceLabel: "Dummy relatiebron uit de Watergang-pagina.",
  turtle: `@prefix object: <https://data.waterschaplimburg.nl/id/objecttype/> .
@prefix relatie: <https://data.waterschaplimburg.nl/def/relatie/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

object:watergang a owl:Class ;
  rdfs:label "Watergang" .

object:watergangsectie a owl:Class ;
  rdfs:label "Watergangsectie" .

object:intersectie a owl:Class ;
  rdfs:label "Intersectie" .

relatie:heeftSectie a owl:ObjectProperty ;
  rdfs:label "Heeft sectie" .

relatie:heeftIntersectie a owl:ObjectProperty ;
  rdfs:label "Heeft intersectie" .

object:watergang relatie:heeftSectie object:watergangsectie .
object:watergang relatie:heeftIntersectie object:intersectie .
`,
  layoutNodes: [
    {
      id: "watergang",
      label: "Watergang",
      subtitle: "Hoofdobject",
      column: 1,
      row: 0,
      fill: "#e4f7fa",
      stroke: "#00a9c1"
    },
    {
      id: "watergangsectie",
      label: "Watergangsectie",
      subtitle: "Onderdeel",
      column: 0,
      row: 1,
      fill: "#eefafb",
      stroke: "#00a9c1"
    },
    {
      id: "intersectie",
      label: "Intersectie",
      subtitle: "Onderdeel",
      column: 2,
      row: 1,
      fill: "#eefafb",
      stroke: "#00a9c1"
    }
  ],
  edges: [
    {
      from: "watergang",
      to: "watergangsectie",
      label: "Heeft sectie"
    },
    {
      from: "watergang",
      to: "intersectie",
      label: "Heeft intersectie"
    }
  ]
};
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Watergangen" }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <dl class="hero-meta-list">
      {(entry.data.metadata || []).map((item) => (
        <div class="hero-meta-item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </Hero>

  <div class="detail-stack">
    <ConceptSummarySection
      subjectLabel="Watergang"
      definition={conceptData?.definition || entry.data.definition}
      synonyms={conceptData?.synonyms || []}
      relatedTerms={conceptData?.relatedTerms || entry.data.terms || []}
      subtypes={conceptData?.types || entry.data.subtypes || []}
    />

    <SemanticSamenhangSection
      title="Decompositie binnen de objectlijn"
      summary="Deze samenhangsweergave laat zien hoe Watergang, Watergangsectie en Intersectie zich tot elkaar verhouden op basis van de ontologische relaties in de dummy begrippen- en objectbron."
      sourceLabel={(samenhangData || fallbackSamenhang).sourceLabel}
      graphId="watergang-samenhang"
      selectedId="watergang"
      turtle={(samenhangData || fallbackSamenhang).turtle}
      layoutNodes={(samenhangData || fallbackSamenhang).layoutNodes}
      edges={(samenhangData || fallbackSamenhang).edges}
    />
  </div>

  <UitwerkingSection title="Inhoudelijke opbouw van Watergang" items={visibleContentSections} />

  <ProductSection eyebrow="Productlijn" items={entry.data.productRelations || []} />

  <section class="section section-panel">
    <p class="eyebrow">Vervolg</p>
    <h2>Logische volgende stappen binnen deze lijn</h2>
    <NextStepsSection items={entry.data.nextSteps || []} />
  </section>
</BaseLayout>

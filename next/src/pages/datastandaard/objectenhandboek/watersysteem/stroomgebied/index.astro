---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../components/Hero.astro";
import CardGrid from "../../../../../components/CardGrid.astro";
import InfoCard from "../../../../../components/InfoCard.astro";
import SemanticSamenhangSection from "../../../../../components/SemanticSamenhangSection.astro";
import { getCollection } from "astro:content";
import { withBase } from "../../../../../lib/paths";
import watersysteemSamenhangTurtle from "../../../../../data/semantic/watersysteem-samenhang.ttl?raw";

const entries = await getCollection("datastandaard-objectenhandboek-objects");
const expectedSlug = "/datastandaard/objectenhandboek/watersysteem/stroomgebied";
const entry = entries.find(
  (item) =>
    item.id === "stroomgebied" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Stroomgebied"
);

if (!entry) {
  throw new Error("Objectenhandboek Stroomgebied ontbreekt in de nieuwe omgeving.");
}

const samenhangLayout = [
  {
    id: "watersysteem",
    label: "Watersysteem",
    subtitle: "Systeem",
    column: 1,
    row: 0,
    fill: "#ffffff",
    stroke: "#00a9c1"
  },
  {
    id: "stroomgebied",
    label: "Stroomgebied",
    subtitle: "Subsysteem",
    column: 1,
    row: 1,
    fill: "#e4f7fa",
    stroke: "#00a9c1"
  },
  {
    id: "watergang",
    label: "Watergang",
    subtitle: "Objectfamilie",
    column: 1,
    row: 2,
    fill: "#eefafb",
    stroke: "#00a9c1"
  },
  {
    id: "watergangsectie",
    label: "Watergangsectie",
    subtitle: "Objecttype",
    column: 0,
    row: 3,
    fill: "#ffffff",
    stroke: "#00a9c1"
  },
  {
    id: "intersectie",
    label: "Intersectie",
    subtitle: "Objecttype",
    column: 2,
    row: 3,
    fill: "#ffffff",
    stroke: "#00a9c1"
  }
];
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Stroomgebied" }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <dl class="hero-meta-list">
      {(entry.data.metadata || []).map((item) => (
        <div class="hero-meta-item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </Hero>

  <section class="section section-panel">
    <p class="eyebrow">Begrip</p>
    <h2>Wat verstaan we onder Stroomgebied?</h2>

    <div class="taxonomy-block">
      <div class="taxonomy-block__header">
        <h3>Objectdefinitie</h3>
        <a class="mini-link" href={withBase("/datastandaard/woordenboek")}>Open begrip in woordenboek</a>
      </div>
      <div class="definition-block">
        <p>{entry.data.definition}</p>
      </div>
      {entry.data.definitionSource && <p class="definition-source">{entry.data.definitionSource}</p>}
    </div>

    <div class="taxonomy-block">
      <h3>Vergelijkbare termen</h3>
      <div class="term-stack">
        {(entry.data.terms || []).map((item) => (
          <a class="term-row" href={withBase(item.href || "/datastandaard/woordenboek")}>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="taxonomy-block">
      <h3>Typen</h3>
      <div class="term-stack">
        {(entry.data.subtypes || []).map((item) => (
          <a class="term-row" href={withBase(item.href || "/datastandaard/woordenboek")}>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="callout">
      <strong>Context</strong>
      <p>{entry.data.contextNote}</p>
    </div>
  </section>

  <SemanticSamenhangSection
    title="Decompositie en hoofdrelaties binnen Stroomgebied"
    summary="Deze samenhangsweergave laat zien hoe Stroomgebied binnen het watersysteem doorloopt naar de eerste uitgewerkte objectfamilie rond Watergang en de onderliggende objecttypen."
    sourceLabel="Dummy Turtle-export uit de semantische modelleertool voor de watersysteemlijn."
    graphId="stroomgebied-samenhang"
    selectedId="stroomgebied"
    turtle={watersysteemSamenhangTurtle}
    layoutNodes={samenhangLayout}
  />

  <section class="section section-panel">
    <p class="eyebrow">Uitwerking</p>
    <h2>Wat werken we vanuit dit subsysteem uit?</h2>
    <CardGrid>
      {(entry.data.contentSections || []).map((item) => (
        <InfoCard title={item.title} text={item.summary} href={item.href} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Productlijn</p>
    <h2>Gerelateerde producten voor Stroomgebied</h2>
    <CardGrid>
      {(entry.data.productRelations || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Vervolg</p>
    <h2>Logische volgende stappen binnen deze lijn</h2>
    <CardGrid>
      {(entry.data.nextSteps || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>
</BaseLayout>

---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../components/Hero.astro";
import ConceptSummarySection from "../../../../../components/ConceptSummarySection.astro";
import SemanticSamenhangSection from "../../../../../components/SemanticSamenhangSection.astro";
import ProductSection from "../../../../../components/ProductSection.astro";
import UitwerkingSection from "../../../../../components/UitwerkingSection.astro";
import GeometrySection from "../../../../../components/GeometrySection.astro";
import VervolgSection from "../../../../../components/VervolgSection.astro";
import { getCollection } from "astro:content";
import { getGeometrySection, normalizeObjectUitwerkingSections } from "../../../../../lib/uitwerkingSections";
import { createKunstwerkTypeGraph } from "../../../../../lib/semanticSamenhangGraphs";

export async function getStaticPaths() {
  const kunstwerkPages = [
    { path: "aquaduct", title: "Aquaduct" },
    { path: "bodemval", title: "Bodemval" },
    { path: "brug", title: "Brug" },
    { path: "coupure", title: "Coupure" },
    { path: "dam", title: "Dam" },
    { path: "duiker", title: "Duiker" },
    { path: "gemaal", title: "Gemaal" },
    { path: "hevel", title: "Hevel" },
    { path: "sifon", title: "Sifon" },
    { path: "stuw", title: "Stuw" },
    { path: "voorde", title: "Voorde" },
    { path: "vuilvang", title: "Vuilvang" },
    { path: "vispassage", title: "Vispassage" },
    { path: "overkluizing", title: "Overkluizing" }
  ];
  const entries = await getCollection("datastandaard-objectenhandboek-objects");

  return kunstwerkPages.map(({ path, title }) => {
    const expectedSlug = `/datastandaard/objectenhandboek/watersysteem/kunstwerken/${path}`;
    const entry = entries.find(
      (item) =>
        item.id === path ||
        item.id === `${path}.md` ||
        item.data.slug === expectedSlug ||
        item.data.slug?.replace(/\/$/, "") === expectedSlug ||
        item.data.title === title
    );

    if (!entry) {
      throw new Error(`Objectenhandboekpagina voor kunstwerktype ${title} ontbreekt.`);
    }

    return {
      params: { kunstwerk: path },
      props: { entry }
    };
  });
}

const { entry } = Astro.props;
const kunstwerkId = Astro.params.kunstwerk || entry.data.slug?.split("/").pop() || "kunstwerktype";
const contentSections = entry.data.contentSections || [];
const uitwerkingSections = normalizeObjectUitwerkingSections(contentSections, {
  subtypes: entry.data.subtypes || [],
  includeTypen: false
});
const geometrySection = getGeometrySection(contentSections);
const samenhangGraph = createKunstwerkTypeGraph(kunstwerkId, entry.data.title);
const escapedTitle = String(entry.data.title || "").replace(/\\/g, "\\\\").replace(/"/g, '\\"');
const kunstwerkTypeTurtle = `@prefix object: <https://data.waterschaplimburg.nl/id/objecttype/> .
@prefix relatie: <https://data.waterschaplimburg.nl/def/relatie/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

object:stroomgebied a owl:Class ;
  rdfs:label "Stroomgebied" .

object:kunstwerk a owl:Class ;
  rdfs:label "Kunstwerk" .

object:${kunstwerkId} a owl:Class ;
  rdfs:label "${escapedTitle}" .

object:watergangsectie a owl:Class ;
  rdfs:label "Watergangsectie" .

object:intersectie a owl:Class ;
  rdfs:label "Intersectie" .

relatie:omvat a owl:ObjectProperty ;
  rdfs:label "omvat" .

relatie:heeftType a owl:ObjectProperty ;
  rdfs:label "heeft type" .

relatie:kanLiggenBij a owl:ObjectProperty ;
  rdfs:label "kan liggen bij" .

object:stroomgebied relatie:omvat object:kunstwerk .
object:kunstwerk relatie:heeftType object:${kunstwerkId} .
object:${kunstwerkId} relatie:kanLiggenBij object:watergangsectie .
object:${kunstwerkId} relatie:kanLiggenBij object:intersectie .
`;
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Kunstwerk", href: "/datastandaard/objectenhandboek/watersysteem/kunstwerken" },
    { label: entry.data.title }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <dl class="hero-meta-list">
      {(entry.data.metadata || []).map((item) => (
        <div class="hero-meta-item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </Hero>

  <ConceptSummarySection
    subjectLabel={entry.data.title}
    definition={entry.data.definition}
    definitionSource={entry.data.definitionSource}
    relatedTerms={entry.data.terms || []}
    subtypes={entry.data.subtypes || []}
  />

  <SemanticSamenhangSection
    title={`Samenhang binnen ${entry.data.title}`}
    summary={`${entry.data.title} is een kunstwerktype binnen de objectfamilie Kunstwerk en wordt in de uitwerking verbonden met de context van watergangsecties en intersecties.`}
    sourceLabel="Dummy Turtle-export uit de semantische modelleertool voor de kunstwerktypepagina's."
    graphId={`kunstwerk-${kunstwerkId}-samenhang`}
    selectedId={kunstwerkId}
    turtle={kunstwerkTypeTurtle}
    layoutNodes={samenhangGraph.layoutNodes}
    edges={samenhangGraph.edges}
  />

  <UitwerkingSection
    title={`Inhoudelijke opbouw van ${entry.data.title}`}
    items={uitwerkingSections}
  />

  <GeometrySection section={geometrySection} />

  <ProductSection eyebrow="Productlijn" items={entry.data.productRelations || []} />

  <VervolgSection title="Logische volgende stappen binnen deze lijn" items={entry.data.nextSteps || []} />
</BaseLayout>

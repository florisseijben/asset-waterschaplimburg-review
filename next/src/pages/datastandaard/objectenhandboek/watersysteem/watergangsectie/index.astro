---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../components/Hero.astro";
import ConceptSummarySection from "../../../../../components/ConceptSummarySection.astro";
import ObjectClassificationSection from "../../../../../components/ObjectClassificationSection.astro";
import SemanticSamenhangSection from "../../../../../components/SemanticSamenhangSection.astro";
import ProductSection from "../../../../../components/ProductSection.astro";
import UitwerkingSection from "../../../../../components/UitwerkingSection.astro";
import GeometrySection from "../../../../../components/GeometrySection.astro";
import VervolgSection from "../../../../../components/VervolgSection.astro";
import { getCollection } from "astro:content";
import watergangSamenhangTurtle from "../../../../../data/semantic/watergang-samenhang.ttl?raw";
import { getGeometrySection, normalizeObjectUitwerkingSections } from "../../../../../lib/uitwerkingSections";
import { createWatergangsectieGraph } from "../../../../../lib/semanticSamenhangGraphs";

const entries = await getCollection("datastandaard-objectenhandboek-objects");
const expectedSlug = "/datastandaard/objectenhandboek/watersysteem/watergangsectie";
const entry = entries.find(
  (item) =>
    item.id === "watergangsectie" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Watergangsectie"
);

if (!entry) {
  throw new Error("Objectenhandboek Watergangsectie ontbreekt in de nieuwe omgeving.");
}

const contentSections = entry.data.contentSections || [];
const visibleContentSections = normalizeObjectUitwerkingSections(contentSections, {
  subtypes: entry.data.subtypes || [],
  subtypeIconTitle: entry.data.heroTitle || entry.data.title
});
const geometrySection = getGeometrySection(contentSections);
const samenhangGraph = createWatergangsectieGraph();
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Watergangen", href: "/datastandaard/objectenhandboek/watersysteem/watergangen" },
    { label: "Watergangsectie" }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary} />

  <ConceptSummarySection
    subjectLabel="Watergangsectie"
    definition={entry.data.definition}
    definitionSource={entry.data.definitionSource}
    relatedTerms={entry.data.terms || []}
    subtypes={entry.data.subtypes || []}
  />

  <SemanticSamenhangSection
    title="Decompositie en hoofdrelaties binnen Watergangsectie"
    summary="Deze samenhangsweergave laat zien hoe Watergangsectie zich verhoudt tot het hoofdobject Watergang en tot Intersectie als parallel objectniveau."
    sourceLabel="Dummy Turtle-export uit de semantische modelleertool voor de waterganglijn."
    graphId="watergangsectie-samenhang"
    selectedId="watergangsectie"
    turtle={watergangSamenhangTurtle}
    layoutNodes={samenhangGraph.layoutNodes}
    edges={samenhangGraph.edges}
  />

  <UitwerkingSection title="Inhoudelijke opbouw van Watergangsectie" items={visibleContentSections} />

  <GeometrySection section={geometrySection} />

  <ProductSection eyebrow="Productlijn" items={entry.data.productRelations || []} />

  <VervolgSection title="Logische volgende stappen binnen deze lijn" items={entry.data.nextSteps || []} />

  <ObjectClassificationSection classification={entry.data.classification} />
</BaseLayout>

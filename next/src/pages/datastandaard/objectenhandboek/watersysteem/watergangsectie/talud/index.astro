---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../../components/Hero.astro";
import ConceptSummarySection from "../../../../../../components/ConceptSummarySection.astro";
import NextStepsSection from "../../../../../../components/NextStepsSection.astro";
import SemanticSamenhangSection from "../../../../../../components/SemanticSamenhangSection.astro";
import ProductSection from "../../../../../../components/ProductSection.astro";
import UitwerkingSection from "../../../../../../components/UitwerkingSection.astro";
import { getCollection } from "astro:content";
import taludSamenhangTurtle from "../../../../../../data/semantic/watergangsectie-talud-samenhang.ttl?raw";

const entries = await getCollection("datastandaard-objectenhandboek-objects");
const expectedSlug = "/datastandaard/objectenhandboek/watersysteem/watergangsectie/talud";
const entry = entries.find(
  (item) =>
    item.id === "talud" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Talud"
);

if (!entry) {
  throw new Error("Objectenhandboek Talud ontbreekt in de nieuwe omgeving.");
}

const samenhangLayout = [
  {
    id: "watergang",
    label: "Watergang",
    subtitle: "Hoofdobject",
    column: 1,
    row: 0,
    fill: "#ffffff",
    stroke: "#00a9c1"
  },
  {
    id: "watergangsectie",
    label: "Watergangsectie",
    subtitle: "Bovenliggend object",
    column: 1,
    row: 1,
    fill: "#eefafb",
    stroke: "#00a9c1"
  },
  {
    id: "talud",
    label: "Talud",
    subtitle: "Objecttype",
    column: 1,
    row: 2,
    fill: "#e4f7fa",
    stroke: "#00a9c1"
  },
  {
    id: "bekledingsconstructie",
    label: "Bekledingsconstructie",
    subtitle: "Onderdeel",
    column: 0,
    row: 3,
    fill: "#eefafb",
    stroke: "#00a9c1"
  },
  {
    id: "bodem",
    label: "Bodem",
    subtitle: "Aangrenzend onderdeel",
    column: 2,
    row: 2,
    fill: "#ffffff",
    stroke: "#00a9c1"
  }
];
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Watergangen", href: "/datastandaard/objectenhandboek/watersysteem/watergangen" },
    { label: "Watergangsectie", href: "/datastandaard/objectenhandboek/watersysteem/watergangsectie" },
    { label: "Talud" }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <dl class="hero-meta-list">
      {(entry.data.metadata || []).map((item) => (
        <div class="hero-meta-item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </Hero>

  <ConceptSummarySection
    subjectLabel="Talud"
    definition={entry.data.definition}
    definitionSource={entry.data.definitionSource}
    relatedTerms={entry.data.terms || []}
    subtypes={entry.data.subtypes || []}
  />

  <SemanticSamenhangSection
    title="Decompositie en hoofdrelaties binnen Talud"
    summary="Deze samenhangsweergave laat zien hoe Talud als onderliggend object van Watergangsectie samenhangt met Watergang, met het aangrenzende onderdeel Bodem en met de constructieve uitwerking via Bekledingsconstructie."
    sourceLabel="Dummy Turtle-export uit de semantische modelleertool voor de watergangsectielijn."
    graphId="talud-samenhang"
    selectedId="talud"
    turtle={taludSamenhangTurtle}
    layoutNodes={samenhangLayout}
  />

  <UitwerkingSection title="Inhoudelijke opbouw van Talud" items={entry.data.contentSections || []} />

  <ProductSection eyebrow="Productlijn" items={entry.data.productRelations || []} />

  <section class="section section-panel">
    <p class="eyebrow">Vervolg</p>
    <h2>Logische volgende stappen binnen deze lijn</h2>
    <NextStepsSection items={entry.data.nextSteps || []} />
  </section>
</BaseLayout>

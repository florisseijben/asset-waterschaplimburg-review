---
import BaseLayout from "../../../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../../../components/Hero.astro";
import CardGrid from "../../../../../../../components/CardGrid.astro";
import InfoCard from "../../../../../../../components/InfoCard.astro";
import ContentSectionCard from "../../../../../../../components/ContentSectionCard.astro";
import NextStepsSection from "../../../../../../../components/NextStepsSection.astro";
import SemanticSamenhangSection from "../../../../../../../components/SemanticSamenhangSection.astro";
import { getCollection } from "astro:content";
import { withBase } from "../../../../../../../lib/paths";
import bekledingsconstructieSamenhangTurtle from "../../../../../../../data/semantic/talud-bekledingsconstructie-samenhang.ttl?raw";

const entries = await getCollection("datastandaard-objectenhandboek-objects");
const expectedSlug = "/datastandaard/objectenhandboek/watersysteem/watergangsectie/talud/bekledingsconstructie";
const entry = entries.find(
  (item) =>
    item.id === "bekledingsconstructie" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Bekledingsconstructie"
);

if (!entry) {
  throw new Error("Objectenhandboek Bekledingsconstructie ontbreekt in de nieuwe omgeving.");
}

const samenhangLayout = [
  {
    id: "watergangsectie",
    label: "Watergangsectie",
    subtitle: "Bovenliggend object",
    column: 1,
    row: 0,
    fill: "#ffffff",
    stroke: "#00a9c1"
  },
  {
    id: "talud",
    label: "Talud",
    subtitle: "Bovenliggend onderdeel",
    column: 1,
    row: 1,
    fill: "#eefafb",
    stroke: "#00a9c1"
  },
  {
    id: "bekledingsconstructie",
    label: "Bekledingsconstructie",
    subtitle: "Objecttype",
    column: 1,
    row: 2,
    fill: "#e4f7fa",
    stroke: "#00a9c1"
  },
  {
    id: "toplaag",
    label: "Toplaag",
    subtitle: "Onderdeel",
    column: 1,
    row: 3,
    fill: "#eefafb",
    stroke: "#00a9c1"
  }
];
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Watergangen", href: "/datastandaard/objectenhandboek/watersysteem/watergangen" },
    { label: "Watergangsectie", href: "/datastandaard/objectenhandboek/watersysteem/watergangsectie" },
    { label: "Talud", href: "/datastandaard/objectenhandboek/watersysteem/watergangsectie/talud" },
    { label: "Bekledingsconstructie" }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <dl class="hero-meta-list">
      {(entry.data.metadata || []).map((item) => (
        <div class="hero-meta-item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </Hero>

  <section class="section section-panel">
    <p class="eyebrow">Begrip</p>
    <h2>Wat verstaan we onder Bekledingsconstructie?</h2>

    <div class="taxonomy-block">
      <div class="taxonomy-block__header">
        <h3>Objectdefinitie</h3>
        <a class="mini-link" href={withBase("/datastandaard/woordenboek")}>Open begrip in woordenboek</a>
      </div>
      <div class="definition-block">
        <p>{entry.data.definition}</p>
      </div>
      {entry.data.definitionSource && <p class="definition-source">{entry.data.definitionSource}</p>}
    </div>

    <div class="taxonomy-block">
      <h3>Vergelijkbare termen</h3>
      <div class="term-stack">
        {(entry.data.terms || []).map((item) => (
          <a class="term-row" href={withBase(item.href || "/datastandaard/woordenboek")}>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="taxonomy-block">
      <h3>Typen</h3>
      <div class="term-stack">
        {(entry.data.subtypes || []).map((item) => (
          <a class="term-row" href={withBase(item.href || "/datastandaard/woordenboek")}>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="callout">
      <strong>Context</strong>
      <p>{entry.data.contextNote}</p>
    </div>
  </section>

  <SemanticSamenhangSection
    title="Decompositie en hoofdrelaties binnen Bekledingsconstructie"
    summary="Deze samenhangsweergave laat zien hoe Bekledingsconstructie onder Talud hangt en minimaal uit een Toplaag bestaat."
    sourceLabel="Dummy Turtle-export uit de semantische modelleertool voor de constructieve lijn binnen Watergangsectie."
    graphId="bekledingsconstructie-samenhang"
    selectedId="bekledingsconstructie"
    turtle={bekledingsconstructieSamenhangTurtle}
    layoutNodes={samenhangLayout}
  />

  <section class="section section-panel">
    <p class="eyebrow">Uitwerking</p>
    <h2>Inhoudelijke opbouw van Bekledingsconstructie</h2>
    <CardGrid stacked={true}>
      {(entry.data.contentSections || []).map((item) => (
        <ContentSectionCard title={item.title} text={item.summary} href={item.href} items={item.items} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Productlijn</p>
    <h2>Andere producten voor Bekledingsconstructie</h2>
    <CardGrid>
      {(entry.data.productRelations || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Vervolg</p>
    <h2>Logische volgende stappen binnen deze lijn</h2>
    <NextStepsSection items={entry.data.nextSteps || []} />
  </section>
</BaseLayout>

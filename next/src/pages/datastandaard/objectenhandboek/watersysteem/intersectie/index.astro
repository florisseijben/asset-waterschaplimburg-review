---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../components/Hero.astro";
import ConceptSummarySection from "../../../../../components/ConceptSummarySection.astro";
import InfoCard from "../../../../../components/InfoCard.astro";
import NextStepsSection from "../../../../../components/NextStepsSection.astro";
import SemanticSamenhangSection from "../../../../../components/SemanticSamenhangSection.astro";
import UitwerkingSection from "../../../../../components/UitwerkingSection.astro";
import { getCollection } from "astro:content";
import watergangSamenhangTurtle from "../../../../../data/semantic/watergang-samenhang.ttl?raw";

const entries = await getCollection("datastandaard-objectenhandboek-objects");
const expectedSlug = "/datastandaard/objectenhandboek/watersysteem/intersectie";
const entry = entries.find(
  (item) =>
    item.id === "intersectie" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Intersectie"
);

if (!entry) {
  throw new Error("Objectenhandboek Intersectie ontbreekt in de nieuwe omgeving.");
}

const visibleContentSections = (entry.data.contentSections || []).filter((item) => item.title !== "Decompositie");
const samenhangLayout = [
  {
    id: "watergang",
    label: "Watergang",
    subtitle: "Hoofdobject",
    column: 1,
    row: 0,
    fill: "#ffffff",
    stroke: "#00a9c1"
  },
  {
    id: "watergangsectie",
    label: "Watergangsectie",
    subtitle: "Parallel objecttype",
    column: 0,
    row: 1,
    fill: "#eefafb",
    stroke: "#00a9c1"
  },
  {
    id: "intersectie",
    label: "Intersectie",
    subtitle: "Objecttype",
    column: 2,
    row: 1,
    fill: "#e4f7fa",
    stroke: "#00a9c1"
  }
];
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Watergangen", href: "/datastandaard/objectenhandboek/watersysteem/watergangen" },
    { label: "Intersectie" }
  ]}
>
  <Hero eyebrow="Objectenhandboek" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <dl class="hero-meta-list">
      {(entry.data.metadata || []).map((item) => (
        <div class="hero-meta-item">
          <dt>{item.label}</dt>
          <dd>{item.value}</dd>
        </div>
      ))}
    </dl>
  </Hero>

    <ConceptSummarySection
      subjectLabel="Intersectie"
      definition={entry.data.definition}
      definitionSource={entry.data.definitionSource}
      relatedTerms={entry.data.terms || []}
      subtypes={entry.data.subtypes || []}
    />

  <SemanticSamenhangSection
    title="Decompositie en hoofdrelaties binnen Intersectie"
    summary="Deze samenhangsweergave laat zien hoe Intersectie zich verhoudt tot het hoofdobject Watergang en tot Watergangsectie als parallel objectniveau."
    sourceLabel="Dummy Turtle-export uit de semantische modelleertool voor de waterganglijn."
    graphId="intersectie-samenhang"
    selectedId="intersectie"
    turtle={watergangSamenhangTurtle}
    layoutNodes={samenhangLayout}
  />

  <UitwerkingSection title="Inhoudelijke opbouw van Intersectie" items={visibleContentSections} />

  <section class="section section-panel">
    <p class="eyebrow">Productlijn</p>
    <h2>Vaste producten binnen de datastandaard</h2>
    <CardGrid>
      {(entry.data.productRelations || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Vervolg</p>
    <h2>Logische volgende stappen binnen deze lijn</h2>
    <NextStepsSection items={entry.data.nextSteps || []} />
  </section>
</BaseLayout>

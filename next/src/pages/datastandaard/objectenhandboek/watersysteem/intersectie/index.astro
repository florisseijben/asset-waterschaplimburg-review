---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import Hero from "../../../../../components/Hero.astro";
import PlaceholderStatus from "../../../../../components/PlaceholderStatus.astro";
---

<BaseLayout
  title="Intersectie"
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Watersysteem", href: "/datastandaard/objectenhandboek/watersysteem" },
    { label: "Intersectie" }
  ]}
>
  <Hero
    eyebrow="Objectenhandboek"
    title="Intersectie"
    summary="Deze vervolgrichting staat klaar voor de volgende inhoudelijke uitwerking binnen de waterganglijn."
  />

  <PlaceholderStatus
    title="Intersectie volgt in een volgende slice"
    summary="De route is al gekoppeld vanuit Watergangen en Watersysteem, zodat de objectlijn volledig navigeerbaar blijft tijdens de migratie."
    scope="kruisingen en snijpunten binnen de watergangstructuur"
  />
</BaseLayout>

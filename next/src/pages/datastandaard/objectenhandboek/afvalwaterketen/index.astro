---
import ObjectenhandboekChapterPage from "../../../../components/ObjectenhandboekChapterPage.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("datastandaard-objectenhandboek-systems");
const expectedSlug = "/datastandaard/objectenhandboek/afvalwaterketen";
const entry = entries.find(
  (item) =>
    item.id === "afvalwaterketen" ||
    item.data.slug === expectedSlug ||
    item.data.title === "Objectenhandboek voor Afvalwaterketen"
);

if (!entry) {
  throw new Error("Objectenhandboek Afvalwaterketen ontbreekt in de nieuwe omgeving.");
}
---

<ObjectenhandboekChapterPage
  entry={entry}
  subjectLabel="Afvalwaterketen"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: "Afvalwaterketen" }
  ]}
/>

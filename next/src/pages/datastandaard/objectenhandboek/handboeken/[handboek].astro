---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Hero from "../../../../components/Hero.astro";
import PrintPageAction from "../../../../components/PrintPageAction.astro";
import { getCollection } from "astro:content";
import { handbookScopes } from "../../../../lib/objectenhandboekHandbooks";
import { normalizeObjectUitwerkingSections } from "../../../../lib/uitwerkingSections";

export function getStaticPaths() {
  return handbookScopes.map((scope) => ({
    params: { handboek: scope.id },
    props: { scope }
  }));
}

const { scope } = Astro.props;
const entries = await getCollection("datastandaard-objectenhandboek-objects");
const collator = new Intl.Collator("nl", { numeric: true, sensitivity: "base" });
const systemHierarchyLabels = new Set([
  "afvalwaterketen",
  "waterketen",
  "watersysteem",
  "waterkeringensysteem",
  "waterkeringen"
]);

const normalizeKey = (value: string) =>
  String(value || "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const getObjectTitle = (entry: any) => entry.data.heroTitle || entry.data.title;

const belongsToScope = (entry: any) => {
  const classification = entry.data.classification || {};
  const values = scope.kind === "system" ? classification.systems : classification.disciplines;

  return Array.isArray(values) && values.includes(scope.id);
};

const createHandbookPath = (entry: any) => {
  const title = getObjectTitle(entry);
  let path = Array.isArray(entry.data.hierarchy) && entry.data.hierarchy.length > 0
    ? entry.data.hierarchy.map(String)
    : [title];

  if (path.length > 1 && systemHierarchyLabels.has(normalizeKey(path[0]))) {
    path = path.slice(1);
  }

  if (path.length > 1 && normalizeKey(path[0]) === "stroomgebied") {
    path = path.slice(1);
  }

  if (!path.some((item) => normalizeKey(item) === normalizeKey(title))) {
    path = [...path, title];
  }

  return path.length ? path : [title];
};

const comparePath = (left: string[], right: string[]) => {
  const length = Math.max(left.length, right.length);

  for (let index = 0; index < length; index += 1) {
    if (left[index] === undefined) {
      return -1;
    }

    if (right[index] === undefined) {
      return 1;
    }

    const comparison = collator.compare(left[index], right[index]);

    if (comparison !== 0) {
      return comparison;
    }
  }

  return 0;
};

const scopedEntries = entries.filter(belongsToScope);
const knownTitles = new Set(scopedEntries.map((entry) => normalizeKey(getObjectTitle(entry))));
const handbookItems = scopedEntries
  .map((entry) => {
    const path = createHandbookPath(entry);
    const looseSubtypes = (entry.data.subtypes || [])
      .filter((subtype: any) => !knownTitles.has(normalizeKey(subtype.title)))
      .sort((left: any, right: any) => collator.compare(left.title, right.title));
    const sections = normalizeObjectUitwerkingSections(entry.data.contentSections || [], {
      subtypes: looseSubtypes,
      subtypeIconTitle: getObjectTitle(entry),
      includeTypen: looseSubtypes.length > 0
    });

    return {
      entry,
      title: getObjectTitle(entry),
      path,
      looseSubtypes,
      sections
    };
  })
  .sort((left, right) => comparePath(left.path, right.path) || collator.compare(left.title, right.title));

const handbookTitle = `Objectenhandboek ${scope.label}`;
const handbookSummary = `${scope.summary} De digitale samenhangsweergaven, productlijn en vervolgstappen zijn in deze printversie weggelaten.`;
---

<BaseLayout
  title={handbookTitle}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
    { label: scope.label, href: scope.landingHref },
    { label: "PDF-overzicht" }
  ]}
>
  <Hero eyebrow="PDF-overzicht" title={handbookTitle} summary={handbookSummary} />

  <PrintPageAction label="Print handboek of maak PDF" />

  {handbookItems.length === 0 ? (
    <section class="section section-panel">
      <p class="eyebrow">Nog geen objecttypen</p>
      <h2>Deze bundel is nog leeg</h2>
      <p class="content-copy">
        Er zijn nog geen objecttypepagina's met deze classificatie. Zodra objecten aan deze ingang worden gekoppeld,
        verschijnen ze automatisch in dit printbare handboek.
      </p>
    </section>
  ) : (
    <div class="handbook-document">
      <section class="section section-panel handbook-toc">
        <p class="eyebrow">Inhoud</p>
        <h2>Objecttypen in deze bundel</h2>
        <ol>
          {handbookItems.map((item) => (
            <li style={`--handbook-level: ${Math.max(item.path.length - 1, 0)};`}>
              <a href={`#${normalizeKey(item.path.join("-"))}`}>{item.path.join(" > ")}</a>
            </li>
          ))}
        </ol>
      </section>

      {handbookItems.map((item) => {
        const { entry } = item;
        const parentPath = item.path.slice(0, -1).join(" > ");
        const printLevel = Math.min(item.path.length, 4);

        return (
          <article
            class={`section section-panel handbook-object handbook-object--level-${printLevel}`}
            id={normalizeKey(item.path.join("-"))}
            style={`--handbook-level: ${Math.min(item.path.length - 1, 3)};`}
          >
            {parentPath && <p class="eyebrow">{parentPath}</p>}
            <h2>{item.title}</h2>
            {entry.data.summary && <p class="lead">{entry.data.summary}</p>}

            <section class="handbook-object__block">
              <h3>Begrip</h3>
              {entry.data.definition && <p>{entry.data.definition}</p>}
              {entry.data.definitionSource && <p class="handbook-object__source">{entry.data.definitionSource}</p>}
              {(entry.data.terms || []).length > 0 && (
                <div>
                  <h4>Gerelateerde begrippen</h4>
                  <ul>
                    {(entry.data.terms || []).map((term: any) => (
                      <li>
                        <strong>{term.title}</strong>
                        {term.text && <span> {term.text}</span>}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </section>

            {item.sections.length > 0 && (
              <section class="handbook-object__block">
                <h3>Uitwerking</h3>
                {item.sections.map((section: any) => (
                  <section class="handbook-object__subsection">
                    <h4>{section.title}</h4>
                    {section.summary && <p>{section.summary}</p>}
                    {(section.items || []).length > 0 && (
                      <ul>
                        {section.items.map((sectionItem: any) => (
                          <li>
                            <strong>{sectionItem.title}</strong>
                            {sectionItem.text && <span> {sectionItem.text}</span>}
                          </li>
                        ))}
                      </ul>
                    )}
                  </section>
                ))}
              </section>
            )}
          </article>
        );
      })}
    </div>
  )}
</BaseLayout>

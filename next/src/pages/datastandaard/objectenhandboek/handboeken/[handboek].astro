---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Hero from "../../../../components/Hero.astro";
import PrintPageAction from "../../../../components/PrintPageAction.astro";
import { getCollection } from "astro:content";
import {
  getObjectHandbookHref,
  getObjectHandbookId,
  handbookScopes
} from "../../../../lib/objectenhandboekHandbooks";
import { objectenhandboekTaxonomy } from "../../../../lib/objectenhandboekTaxonomy";
import { withBase } from "../../../../lib/paths";
import { normalizeObjectUitwerkingSections } from "../../../../lib/uitwerkingSections";

export async function getStaticPaths() {
  const objectEntries = await getCollection("datastandaard-objectenhandboek-objects");
  const objectScopes = objectEntries.map((entry) => ({
    id: getObjectHandbookId(entry.id),
    kind: "object" as const,
    label: entry.data.heroTitle || entry.data.title,
    href: getObjectHandbookHref(entry.id),
    landingHref: entry.data.slug,
    objectEntryId: entry.id,
    summary: `Printbare versie van ${entry.data.heroTitle || entry.data.title}, opgebouwd uit definitie, begrip en inhoudelijke uitwerking.`
  }));

  return [...handbookScopes, ...objectScopes].map((scope) => ({
    params: { handboek: scope.id },
    props: { scope }
  }));
}

const { scope } = Astro.props;
const entries = await getCollection("datastandaard-objectenhandboek-objects");
const collator = new Intl.Collator("nl", { numeric: true, sensitivity: "base" });
const systemHierarchyLabels = new Set([
  "afvalwaterketen",
  "waterketen",
  "watersysteem",
  "waterkeringensysteem",
  "waterkeringen"
]);

const normalizeKey = (value: string) =>
  String(value || "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const getObjectTitle = (entry: any) => entry.data.heroTitle || entry.data.title;
const chapterLabelsByRoot = new Map([
  ["kunstwerk", "Kunstwerken"],
  ["kunstwerken", "Kunstwerken"],
  ["regenwaterbuffer", "Regenwaterbuffers"],
  ["regenwaterbuffers", "Regenwaterbuffers"],
  ["stroomgebied", "Stroomgebieden"],
  ["stroomgebieden", "Stroomgebieden"],
  ["watergang", "Watergangen"],
  ["watergangen", "Watergangen"],
  ["watergangsectie", "Watergangen"],
  ["intersectie", "Watergangen"]
]);
const objectFamilyLabelById = new Map(
  objectenhandboekTaxonomy.objectFamilies.map((family) => [family.id, family.label])
);

const belongsToScope = (entry: any) => {
  const classification = entry.data.classification || {};

  if (scope.kind === "all") {
    return true;
  }

  if (scope.kind === "object") {
    return entry.id === scope.objectEntryId;
  }

  const values = scope.kind === "system" ? classification.systems : classification.disciplines;

  return Array.isArray(values) && values.includes(scope.id);
};

const createHandbookPath = (entry: any) => {
  const title = getObjectTitle(entry);
  let path = Array.isArray(entry.data.hierarchy) && entry.data.hierarchy.length > 0
    ? entry.data.hierarchy.map(String)
    : [title];

  if (path.length > 1 && systemHierarchyLabels.has(normalizeKey(path[0]))) {
    path = path.slice(1);
  }

  if (path.length > 1 && normalizeKey(path[0]) === "stroomgebied") {
    path = path.slice(1);
  }

  if (!path.some((item) => normalizeKey(item) === normalizeKey(title))) {
    path = [...path, title];
  }

  return path.length ? path : [title];
};

const getPrimaryObjectFamilyLabel = (entry: any) => {
  const objectFamilyId = entry.data.classification?.objectFamilies?.[0];

  return objectFamilyLabelById.get(objectFamilyId) || "Overige objecttypen";
};

const getChapterLabel = (path: string[], entry: any) => {
  const root = normalizeKey(path[0] || getObjectTitle(entry));

  return chapterLabelsByRoot.get(root) || getPrimaryObjectFamilyLabel(entry);
};

type HandbookNode = {
  title: string;
  path: string[];
  entry?: any;
  summary?: string;
  text?: string;
  sections: any[];
  children: HandbookNode[];
};

function getOrCreateNode(nodes: HandbookNode[], title: string, path: string[]) {
  const key = normalizeKey(title);
  const existing = nodes.find((node) => normalizeKey(node.title) === key);

  if (existing) {
    return existing;
  }

  const node: HandbookNode = {
    title,
    path,
    sections: [],
    children: []
  };

  nodes.push(node);
  return node;
}

function insertNode(nodes: HandbookNode[], path: string[], payload: Partial<HandbookNode>) {
  let currentNodes = nodes;
  let node: HandbookNode | undefined;

  path.forEach((title, index) => {
    node = getOrCreateNode(currentNodes, title, path.slice(0, index + 1));
    currentNodes = node.children;
  });

  if (!node) {
    return;
  }

  node.entry = payload.entry || node.entry;
  node.summary = payload.summary || node.summary;
  node.text = payload.text || node.text;
  node.sections = payload.sections || node.sections;
}

const getNodeSortRank = (title: string) => {
  const key = normalizeKey(title);

  if (key === "typen") {
    return 0;
  }

  if (key === "onderdelen") {
    return 1;
  }

  return 2;
};

function sortNodes(nodes: HandbookNode[]) {
  nodes.sort(
    (left, right) =>
      getNodeSortRank(left.title) - getNodeSortRank(right.title) ||
      collator.compare(left.title, right.title)
  );
  nodes.forEach((node) => sortNodes(node.children));
}

function flattenNodes(nodes: HandbookNode[], prefix: number[] = [], depth = 1, startIndex = 0): any[] {
  return nodes.flatMap((node, index) => {
    const numberParts = [...prefix, startIndex + index + 1];
    const numberedNode = {
      ...node,
      depth,
      number: numberParts.join("."),
      id: `${numberParts.join("-")}-${normalizeKey(node.path.join("-"))}`
    };

    return [numberedNode, ...flattenNodes(node.children, numberParts, depth + 1)];
  });
}

const allEntryByTitleKey = new Map(entries.map((entry) => [normalizeKey(getObjectTitle(entry)), entry]));
const chapterMap = new Map<string, { label: string; nodes: HandbookNode[] }>();

const isCompositionTypeOfParent = (parentEntry: any, childTitle: string) =>
  (parentEntry.data.compositionTypes || []).some(
    (compositionType: any) => normalizeKey(compositionType.title) === normalizeKey(childTitle)
  );

const isAllowedInHandbookTree = (entry: any) => {
  const path = createHandbookPath(entry);

  return path.every((title, index) => {
    if (index === 0) {
      return true;
    }

    const parentEntry = allEntryByTitleKey.get(normalizeKey(path[index - 1]));

    if (!parentEntry || !(parentEntry.data.compositionTypes || []).length) {
      return true;
    }

    return isCompositionTypeOfParent(parentEntry, title);
  });
};

const scopedEntries = entries.filter((entry) => belongsToScope(entry) && isAllowedInHandbookTree(entry));

const createCategorizedPath = (entry: any) => {
  return createHandbookPath(entry);
};

const getPrintableSections = (entry: any) =>
  normalizeObjectUitwerkingSections(entry.data.contentSections || [], {
    compositionTypes: entry.data.compositionTypes || [],
    subtypeIconTitle: getObjectTitle(entry),
    includeTypen: true
  });

scopedEntries.forEach((entry) => {
  const path = createHandbookPath(entry);
  const categorizedPath = createCategorizedPath(entry);
  const chapterLabel = getChapterLabel(path, entry);
  const chapter = chapterMap.get(chapterLabel) || { label: chapterLabel, nodes: [] };
  insertNode(chapter.nodes, categorizedPath, {
    entry,
    title: getObjectTitle(entry),
    path: categorizedPath,
    summary: entry.data.summary,
    sections: getPrintableSections(entry)
  });

  chapterMap.set(chapterLabel, chapter);
});

const handbookChapters = [...chapterMap.values()]
  .map((chapter) => {
    sortNodes(chapter.nodes);

    return chapter;
  })
  .sort((left, right) => collator.compare(left.label, right.label))
  .map((chapter, index) => {
    const promotedRoot = chapter.nodes.length === 1 && chapter.nodes[0].children.length > 0
      ? chapter.nodes[0]
      : undefined;
    const introNode = promotedRoot?.entry ? promotedRoot : undefined;
    const printableNodes = promotedRoot ? promotedRoot.children : chapter.nodes;
    const introNumber = introNode ? `${index + 1}.1` : undefined;
    const flatNodes = flattenNodes(printableNodes, [index + 1], 1, introNode ? 1 : 0);
    const tocIntroNode = introNode && introNumber
      ? [{ ...introNode, depth: 1, number: introNumber, id: normalizeKey(chapter.label) }]
      : [];

    return {
      ...chapter,
      introNode,
      introNumber,
      nodes: printableNodes,
      number: String(index + 1),
      id: normalizeKey(chapter.label),
      flatNodes,
      tocNodes: [...tocIntroNode, ...flatNodes]
    };
  });

const handbookItemCount = handbookChapters.reduce((count, chapter) => count + chapter.flatNodes.length, 0);

const handbookTitle = scope.kind === "all" ? "Objectenhandboek" : `Objectenhandboek ${scope.label}`;
const handbookSummary = `${scope.summary} De digitale samenhangsweergaven, productlijn en vervolgstappen zijn in deze printversie weggelaten.`;
const handbookBreadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Datastandaard", href: "/datastandaard" },
  { label: "Objectenhandboek", href: "/datastandaard/objectenhandboek" },
  ...(scope.kind === "all" ? [] : [{ label: scope.label, href: scope.landingHref }]),
  { label: "Printbare versie" }
];
---

<BaseLayout
  title={handbookTitle}
  currentPath="/datastandaard"
  breadcrumbs={handbookBreadcrumbs}
>
  <Hero eyebrow="Printbare versie" title={handbookTitle} summary={handbookSummary} />

  <PrintPageAction label="Print handboek of maak PDF" />

  {handbookItemCount === 0 ? (
    <section class="section section-panel">
      <p class="eyebrow">Nog geen objecttypen</p>
      <h2>Deze bundel is nog leeg</h2>
      <p class="content-copy">
        Er zijn nog geen objecttypepagina's met deze classificatie. Zodra objecten aan deze ingang worden gekoppeld,
        verschijnen ze automatisch in dit printbare handboek.
      </p>
    </section>
  ) : (
    <div class="handbook-document">
      <aside class="section-panel handbook-toc" aria-label="Inhoudsopgave">
        <p class="eyebrow">Inhoud</p>
        <h2>Inhoudsopgave</h2>
        <ol class="handbook-toc__chapters">
          {handbookChapters.map((chapter) => (
            <li class="handbook-toc__chapter">
              <details class="handbook-toc__details" open>
                <summary class="handbook-toc__summary">
                  <span class="handbook-number">{chapter.number}</span>
                  <a
                    class="handbook-toc__chapter-link"
                    href={`#${chapter.id}`}
                    onclick="event.stopPropagation()"
                  >
                    {chapter.label}
                  </a>
                </summary>
                <ol class="handbook-toc__sections">
                  {chapter.tocNodes.map((item) => (
                    <li
                      class="handbook-toc__section"
                      style={`--handbook-level: ${Math.max(item.depth - 1, 0)};`}
                    >
                      <a class="handbook-toc__link" href={`#${item.id}`}>
                        <span class="handbook-number">{item.number}</span>
                        <span>{item.title}</span>
                      </a>
                    </li>
                  ))}
                </ol>
              </details>
            </li>
          ))}
        </ol>
      </aside>

      <div class="handbook-content">
        {handbookChapters.map((chapter) => (
          <section class="section handbook-chapter" id={chapter.id}>
            <header class="section-panel handbook-chapter__heading">
              <p class="eyebrow">Hoofdstuk {chapter.number}</p>
              <h2>
                <span class="handbook-number">{chapter.number}</span>
                <span>{chapter.label}</span>
              </h2>
              {chapter.introNode && (
                <div class="handbook-chapter__intro">
                  {chapter.introNumber && (
                    <h3 class="handbook-object__numbered-heading">
                      <span class="handbook-number">{chapter.introNumber}</span>
                      <span>{chapter.introNode.title}</span>
                    </h3>
                  )}
                  {chapter.introNode.summary && <p class="lead">{chapter.introNode.summary}</p>}

                  <section class="handbook-object__block">
                    <h4 class="handbook-object__numbered-heading">
                      <span class="handbook-number">{chapter.introNumber}.1</span>
                      <span>Begrip</span>
                    </h4>
                    {chapter.introNode.entry.data.definition && <p>{chapter.introNode.entry.data.definition}</p>}
                    {chapter.introNode.entry.data.definitionSource && (
                      <p class="handbook-object__source">{chapter.introNode.entry.data.definitionSource}</p>
                    )}
                  </section>

                  {chapter.introNode.sections.length > 0 && (
                    <section class="handbook-object__block">
                      <h4 class="handbook-object__numbered-heading">
                        <span class="handbook-number">{chapter.introNumber}.2</span>
                        <span>Uitwerking</span>
                      </h4>
                      {chapter.introNode.sections.map((section: any, sectionIndex: number) => (
                        <section class="handbook-object__subsection">
                          <h5 class="handbook-object__numbered-heading">
                            <span class="handbook-number">{chapter.introNumber}.2.{sectionIndex + 1}</span>
                            <span>{section.title}</span>
                          </h5>
                          {section.summary && <p>{section.summary}</p>}
                          {section.image?.src && (
                            <figure class="handbook-object__figure">
                              <img
                                class="handbook-object__image"
                                src={withBase(section.image.src)}
                                alt={section.image.alt || ""}
                                loading="lazy"
                              />
                              {section.caption && <figcaption class="handbook-object__caption">{section.caption}</figcaption>}
                            </figure>
                          )}
                          {(section.items || []).length > 0 && (
                            <ul>
                              {section.items.map((sectionItem: any) => (
                                <li>
                                  <strong>{sectionItem.title}</strong>
                                  {sectionItem.text && <span> {sectionItem.text}</span>}
                                  {sectionItem.image?.src && (
                                    <figure class="handbook-object__figure">
                                      <img
                                        class="handbook-object__image"
                                        src={withBase(sectionItem.image.src)}
                                        alt={sectionItem.image.alt || ""}
                                        loading="lazy"
                                      />
                                      {sectionItem.caption && (
                                        <figcaption class="handbook-object__caption">{sectionItem.caption}</figcaption>
                                      )}
                                    </figure>
                                  )}
                                </li>
                              ))}
                            </ul>
                          )}
                        </section>
                      ))}
                    </section>
                  )}
                </div>
              )}
            </header>

            {chapter.flatNodes.map((item) => {
              const entry = item.entry;

              return (
                <article
                  class:list={[
                    "section-panel",
                    "handbook-object",
                    `handbook-object--depth-${Math.min(item.depth, 4)}`
                  ]}
                  id={item.id}
                  style={`--handbook-level: ${Math.min(item.depth - 1, 3)};`}
                >
                  <p class="eyebrow">Paragraaf {item.number}</p>
                  <h3>
                    <span class="handbook-number">{item.number}</span>
                    <span>{item.title}</span>
                  </h3>
                  {item.summary && <p class="lead">{item.summary}</p>}

                  {entry ? (
                    <>
                      <section class="handbook-object__block">
                        <h4 class="handbook-object__numbered-heading">
                          <span class="handbook-number">{item.number}.1</span>
                          <span>Begrip</span>
                        </h4>
                        {entry.data.definition && <p>{entry.data.definition}</p>}
                        {entry.data.definitionSource && (
                          <p class="handbook-object__source">{entry.data.definitionSource}</p>
                        )}
                        {(entry.data.terms || []).length > 0 && (
                          <div>
                            <h5 class="handbook-object__numbered-heading">
                              <span class="handbook-number">{item.number}.1.1</span>
                              <span>Gerelateerde begrippen</span>
                            </h5>
                            <ul>
                              {(entry.data.terms || []).map((term: any) => (
                                <li>
                                  <strong>{term.title}</strong>
                                  {term.text && <span> {term.text}</span>}
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </section>

                      {item.sections.length > 0 && (
                        <section class="handbook-object__block">
                          <h4 class="handbook-object__numbered-heading">
                            <span class="handbook-number">{item.number}.2</span>
                            <span>Uitwerking</span>
                          </h4>
                          {item.sections.map((section: any, sectionIndex: number) => (
                            <section class="handbook-object__subsection">
                              <h5 class="handbook-object__numbered-heading">
                                <span class="handbook-number">{item.number}.2.{sectionIndex + 1}</span>
                                <span>{section.title}</span>
                              </h5>
                              {section.summary && <p>{section.summary}</p>}
                              {section.image?.src && (
                                <figure class="handbook-object__figure">
                                  <img
                                    class="handbook-object__image"
                                    src={withBase(section.image.src)}
                                    alt={section.image.alt || ""}
                                    loading="lazy"
                                  />
                                  {section.caption && <figcaption class="handbook-object__caption">{section.caption}</figcaption>}
                                </figure>
                              )}
                              {(section.items || []).length > 0 && (
                                <ul>
                                  {section.items.map((sectionItem: any) => (
                                    <li>
                                      <strong>{sectionItem.title}</strong>
                                      {sectionItem.text && <span> {sectionItem.text}</span>}
                                      {sectionItem.image?.src && (
                                        <figure class="handbook-object__figure">
                                          <img
                                            class="handbook-object__image"
                                            src={withBase(sectionItem.image.src)}
                                            alt={sectionItem.image.alt || ""}
                                            loading="lazy"
                                          />
                                          {sectionItem.caption && (
                                            <figcaption class="handbook-object__caption">{sectionItem.caption}</figcaption>
                                          )}
                                        </figure>
                                      )}
                                    </li>
                                  ))}
                                </ul>
                              )}
                            </section>
                          ))}
                        </section>
                      )}
                    </>
                  ) : (
                    item.text && item.text !== item.summary && (
                      <section class="handbook-object__block">
                        <h4>Korte omschrijving</h4>
                        <p>{item.text}</p>
                      </section>
                    )
                  )}
                </article>
              );
            })}
          </section>
        ))}
      </div>
    </div>
  )}
</BaseLayout>

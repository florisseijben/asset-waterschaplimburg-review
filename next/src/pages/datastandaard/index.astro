---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import CardGrid from "../../components/CardGrid.astro";
import InfoCard from "../../components/InfoCard.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("datastandaard-landing");
const entry = entries[0];

if (!entry) {
  throw new Error("Datastandaard-landing ontbreekt in de nieuwe omgeving.");
}
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Datastandaard" }]}
>
  <Hero eyebrow="Datastandaard" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary} />

  <section class="section section-panel">
    <p class="eyebrow">Benadering</p>
    <h2>Hoe wil je de datastandaard benaderen?</h2>
    <h3 class="section-title">Systemen</h3>
    <CardGrid>
      {(entry.data.systems || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
    <h3 class="section-title">Technische disciplines</h3>
    <CardGrid>
      {(entry.data.disciplines || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Producten</p>
    <h2>Vaste producten binnen de datastandaard</h2>
    <CardGrid>
      {(entry.data.products || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>
</BaseLayout>

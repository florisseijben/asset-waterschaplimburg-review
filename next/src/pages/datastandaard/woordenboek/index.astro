---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import CardGrid from "../../../components/CardGrid.astro";
import InfoCard from "../../../components/InfoCard.astro";
import { getCollection } from "astro:content";
import { withBase } from "../../../lib/paths";

const entries = await getCollection("datastandaard-woordenboek");
const entry = entries[0];

if (!entry) {
  throw new Error("Woordenboek-landing ontbreekt in de nieuwe omgeving.");
}
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Woordenboek" }
  ]}
>
  <Hero eyebrow="Product" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary} />

  <section class="section section-panel">
    <p class="eyebrow">Zoeken en filteren</p>
    <h2>Doorzoek het woordenboek op metadata</h2>
    <div class="content-copy">
      <p>{entry.data.searchIntro}</p>
      <p>De echte zoek- en filterfunctionaliteit volgt in een latere stap als eerste interactieve island.</p>
    </div>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Productrelaties</p>
    <h2>Snel naar productlijnen voor Watersysteem</h2>
    <CardGrid>
      {(entry.data.productRelations || []).map((group) => (
        <article class="info-card">
          <h2>{group.title}</h2>
          <div class="link-row">
            {group.links.map((link) => (
              link.href ? (
                <a class="mini-link" href={withBase(link.href)}>{link.label}</a>
              ) : (
                <span class="mini-link mini-link--muted">{link.label}</span>
              )
            ))}
          </div>
        </article>
      ))}
    </CardGrid>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Volgende uitbreidingen</p>
    <h2>Wat hierna volgt in deze productlijn</h2>
    <CardGrid>
      {(entry.data.nextCapabilities || []).map((item) => (
        <InfoCard title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import CardGrid from "../../../components/CardGrid.astro";
import InfoCard from "../../../components/InfoCard.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("datastandaardWoordenboek", "index");

if (!entry) {
  throw new Error("Woordenboek-landing ontbreekt in de nieuwe omgeving.");
}
---

<BaseLayout
  title={entry.data.title}
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Woordenboek" }
  ]}
>
  <Hero eyebrow="Woordenboek" title={entry.data.title} summary={entry.data.summary} />

  <section class="section section-panel">
    <p class="eyebrow">Doel</p>
    <h2>Eerste productreferentie in de migratie</h2>
    <div class="content-copy">
      <p>Deze route test hoe productmetadata, gedeelde layout en productnavigatie uit elkaar getrokken kunnen worden.</p>
      <p>In een volgende stap kunnen hier begrippenlijsten, zoekingangen en termdetails op aansluiten.</p>
    </div>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Volgende uitbreidingen</p>
    <CardGrid>
      <InfoCard title="Begrippenlijst" text="Een eerste indexroute met termen en filtering." />
      <InfoCard title="Termdetail" text="Een detailtemplate waarin definitie, bron en relaties samenkomen." />
      <InfoCard title="Zoekingang" text="Een gerichte woordenboekzoekfunctie als eerste island." />
    </CardGrid>
  </section>
</BaseLayout>

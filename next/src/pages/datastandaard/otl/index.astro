---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import ConceptSummarySection from "../../../components/ConceptSummarySection.astro";
import PlaceholderStatus from "../../../components/PlaceholderStatus.astro";

---

<BaseLayout
  title="Object Type Library"
  currentPath="/datastandaard"
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Datastandaard", href: "/datastandaard" },
    { label: "Object Type Library" }
  ]}
>
  <Hero
    eyebrow="Product"
    title="Object Type Library"
    summary="Op deze pagina vind je wat de Object Type Library biedt: objecttypen met eigenschappen, relaties, gedrag en de basis voor eisen en verificaties in een gestandaardiseerd model."
  />

  <ConceptSummarySection
    subjectLabel="Object Type Library (OTL)"
    definition="Een ObjectType Library (OTL) is een gestructureerde verzameling van objecttypen die binnen een bepaald systeem of discipline worden gebruikt. Elk objecttype binnen de bibliotheek definieert de eigenschappen, relaties en het gedrag van een bepaald type object in een gestandaardiseerde vorm. Ook biedt dit de basis om eisen en verificaties aan elk object te koppelen. Deze bibliotheken worden vaak gebruikt om consistentie te creëren en samenwerking te bevorderen."
    relatedTerms={[
      { title: "Objecttype", text: "Basiseenheid binnen de bibliotheek waarvoor eigenschappen, relaties en gedrag worden vastgelegd.", href: "/datastandaard/woordenboek" },
      { title: "Relaties", text: "Samenhangen tussen objecttypen binnen een systeem, discipline of model.", href: "/datastandaard/woordenboek" },
      { title: "Eisen en verificaties", text: "Koppelingen waarmee objecttypen ook gebruikt kunnen worden voor toetsing en borging.", href: "/datastandaard/woordenboek" }
    ]}
  />

  <PlaceholderStatus
    title="Object Type Library volgt inhoudelijk in een volgende slice"
    summary="De productroute is nu inhoudelijk gepositioneerd en kan in een volgende stap verder worden uitgewerkt met modelroutes, relatieverkenning en graphfunctionaliteit."
    scope="OTL-landingen, modelroutes en Reactodia-gerelateerde verkenning"
  />
</BaseLayout>

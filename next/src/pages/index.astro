---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CardGrid from "../components/CardGrid.astro";
import InfoCard from "../components/InfoCard.astro";
import { getEntry } from "astro:content";

const entry = await getEntry("platform", "home");

if (!entry) {
  throw new Error("Home-content ontbreekt in de nieuwe omgeving.");
}
---

<BaseLayout title={entry.data.title} currentPath="/" breadcrumbs={[{ label: "Home" }]}>
  <Hero eyebrow="Home" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <div class="actions">
      {(entry.data.heroActions || []).map((action) => (
        <a class={`button ${action.variant === "primary" ? "button-primary" : "button-secondary"}`} href={action.href}>
          {action.label}
        </a>
      ))}
    </div>
  </Hero>

  <section class="section section-panel">
    <p class="eyebrow">Platformlogica</p>
    <h2>Van bronafspraak naar aantoonbaar beheer</h2>
    <div class="card-grid">
      {(entry.data.platformFlow || []).map((item) => (
        <InfoCard title={item.title} text={item.text} />
      ))}
    </div>
  </section>

  <section class="section section-panel">
    <p class="eyebrow">Onderdelen</p>
    <h2>Kies een onderdeel</h2>
    <div class="card-grid">
      {(entry.data.parts || []).map((item) => (
        <InfoCard eyebrow="Onderdeel" title={item.title} text={item.text} href={item.href} />
      ))}
    </div>
  </section>
</BaseLayout>

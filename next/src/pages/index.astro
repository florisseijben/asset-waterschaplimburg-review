---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CardGrid from "../components/CardGrid.astro";
import InfoCard from "../components/InfoCard.astro";
import { getCollection } from "astro:content";
import { withBase } from "../lib/paths";

const entries = await getCollection("platform");
const entry = entries[0];

if (!entry) {
  throw new Error("Home-content ontbreekt in de nieuwe omgeving.");
}
---

<BaseLayout title={entry.data.title} currentPath="/" breadcrumbs={[{ label: "Home" }]}>
  <Hero eyebrow="Home" title={entry.data.heroTitle || entry.data.title} summary={entry.data.summary}>
    <div class="actions">
      {(entry.data.heroActions || []).map((action) => (
        <a class={`button ${action.variant === "primary" ? "button-primary" : "button-secondary"}`} href={withBase(action.href)}>
          {action.label}
        </a>
      ))}
    </div>
  </Hero>

  <section class="section section-panel">
    <p class="eyebrow">Onderdelen</p>
    <h2>Kies een onderdeel</h2>
    <CardGrid>
      {(entry.data.parts || []).map((item, index) => (
        <InfoCard eyebrow={`Onderdeel ${index + 1}`} title={item.title} text={item.text} href={item.href} />
      ))}
    </CardGrid>
  </section>
</BaseLayout>
